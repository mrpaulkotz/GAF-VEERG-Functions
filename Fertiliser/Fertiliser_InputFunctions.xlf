  Scope3Array,
  ChemicalCompoundColumn,
  Source,
  SourceRow,
  INDEX(
    Scope3Array,
    MATCH(
      ChemicalCompound,
      ChemicalCompoundColumn,
      0
    ),
    MATCH(
      Source,
      SourceRow,
      0
    )
  )
);

