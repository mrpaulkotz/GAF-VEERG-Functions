Fertiliser_TotalActiveIngredientAppliedAllIngredients
=LAMBDA(
  ChemicalCompound,
  AmountApplied,
  ProductIngredient1,
  ProductIngredientUnit1,
  ProductIngredientPercent1,
  [ProductIngredient2],
  [ProductIngredientUnit2],
  [ProductIngredientPercent2],
  [ProductIngredient3],
  [ProductIngredientUnit3],
  [ProductIngredientPercent3],
  LET(
    calculatedAmount1,
    (
      IF(
        ProductIngredientUnit1 = "Percent of product",
        AmountApplied * ProductIngredientPercent1,
        AmountApplied *(
          ProductIngredientPercent1 * 10 ^ - 3
        )
      )
    ),
    calculatedAmount2,
    (
      IF(
        ProductIngredientUnit1 = "Percent of product",
        AmountApplied * ProductIngredientPercent2,
        AmountApplied *(
          ProductIngredientPercent2 * 10 ^ - 3
        )
      )
    ),
    calculatedAmount3,
    (
      IF(
        ProductIngredientUnit1 = "Percent of product",
        AmountApplied * ProductIngredientPercent3,
        AmountApplied *(
          ProductIngredientPercent3 * 10 ^ - 3
        )
      )
    ),
    Fertiliser_InputFunctions.Fertiliser_SumProductApplied(
      ChemicalCompound,
      ProductIngredient1,
      calculatedAmount1
    ) + IFERROR(
      Fertiliser_InputFunctions.Fertiliser_SumProductApplied(
        ChemicalCompound,
        ProductIngredient2,
        calculatedAmount2
      ),
      0
    ) + IFERROR(
      Fertiliser_InputFunctions.Fertiliser_SumProductApplied(
        ChemicalCompound,
        ProductIngredient3,
        calculatedAmount3
      ),
      0
    )
  )
)