VEERG_6_1_1_1__1__NitrousOxideEmissionsFromCropResidues_LatexEquation
  =LAMBDA("E=\sum\nolimits_c\left(M_{c}\times EF_{N}\right)\times C_{g,N2O}\times 10^{-3}");

