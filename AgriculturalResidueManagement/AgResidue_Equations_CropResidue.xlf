VEERG_6_1_1_1__2__MassOfNitrogenInCropResidues_LatexEquation
  =LAMBDA("M_{c}=(P_{c}\times R_{AGc}\times(1-F_{c}-FFOD_{c})\times DM_{c}\times NC_{AGc})+(P_{c}\times R_{AGc}\times R_{BGc}\times DM_{c}\times NC_{BGc})");

