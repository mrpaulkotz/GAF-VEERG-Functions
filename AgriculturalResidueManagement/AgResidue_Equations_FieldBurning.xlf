/* 
--------------------------------------
VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues
Methane emissions from the burning of crop residues
ECH4
t CH4
E_{CH4}=
\sum_{c}(M_{burn,c}\times CC_{c}\times EF_{CH4}\times C_{CH4}\times 10^{-3})
M_burnc = mass of residue burnt for crop type c (kg)
CC_c = carbon mass fraction in the residues of crop type c (dimensionless)
EF_CH4 = emission factor for methane from burning of crop residues (kg CH4/kg CH4 burnt)
CCH4 = factor to convert elemental mass of methane to molecular mass (dimensionless)
c = Crop type
--------------------------------------
*/

VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues
  =LAMBDA(
    M_burnc, CC_c, EF_CH4, C_CH4,
    (M_burnc * CC_c) * EF_CH4 * C_CH4 * 10^(-3)
  );

VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues_FunctionName
  =LAMBDA("VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues");

