/* 
--------------------------------------
VEERG_6_4_1_1__3__MassOfCropResidueBurnt
Mass of residue of crop c burnt
M_burnc
kg
M_{burn,c}=P_{c}\times R_{AGc}\times S_{c}\times DM_{c}\times Z_{c}\times F_{c}
P_c = annual production of crop type c (kg)
R_AGc = residue to crop ratio of crop type c (kg crop residue/kg crop)
S_c = fraction of residues of crop type c remaining at burning (dimensionless)
DM_c = dry matter content of crop type c (kg dry weight/kg crop residue)
Z_c = burning efficiency (ratio of fuel burnt to fuel load) of crop type c (dimensionless)
F_c = fraction of the annual production of crop type c that is burnt (dimensionless)
c = Crop type
--------------------------------------
*/

VEERG_6_4_1_1__3__MassOfCropResidueBurnt
  =LAMBDA(
    P_c, R_AGc, S_c, DM_c, Z_c, F_c,
    P_c * R_AGc * S_c * DM_c * Z_c * F_c
  );

