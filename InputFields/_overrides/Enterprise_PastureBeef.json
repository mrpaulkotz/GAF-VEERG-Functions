      "Message": "Head sold ({amount}) for {class} in {period} can't exceed the head available ({available})."
    },
    {
      "Rule": "LiveweightWithinTolerance",
      "SalesTable": "Table_Input_LivestockSales",
      "ClassColumn": "Class",
      "DateColumn": "SaleDate",
      "ValueColumn": "AverageWeightPerHead",
      "Tolerance": 0.2,
      "MethodSwitch": { "Fields": ["X_Cell_PastureBeef_Method1OrMethod2", "DataEntryMethod"], "Method1": "Method 1", "Method2": "Method 2" },
      "ReferenceMethod1": { "Table": "X_Table_PastureBeef_Liveweight_Method1", "Period": "season" },
      "ReferenceMethod2": { "Table": "X_Table_PastureBeef_Liveweight_Method2", "Period": "month" },
      "Message": "Average weight per head ({value} kg) for {class} in {period} must be within {tolerancePct}% of the expected liveweight ({reference} kg)."
    },
    {
      "Rule": "DateWithinActivityPeriod",
      "Tables": [
        { "Table": "Table_Input_LivestockSales", "DateColumn": "SaleDate", "Label": "Sale" },
        { "Table": "Table_Input_LivestockPurchases_Beefcattle", "DateColumn": "PurchaseDate", "Label": "Purchase" }
      ],
      "Message": "{label} date {date} is outside the activity period ({min} to {max})."
    }
  ]
