/*
--------------------------------------
VEERG_15_12_1_2__1_UpstreamPurchasedElectricityMarketBased
Scope 3 emissions from purchased electricity market based
E_3elec
t CO2e
E_{3,elec}=\left[Q_{elec}\times\left(1-(RPP+JRPP)\right)-\left(REC_{surrendered}-REC_{onsite}\right)\times 10^{-3}\right]\times EF_{RMF3,elec}\times 10^{-3}
Q_elec = amount of electricity purchased from the grid
RPP = renewable power percentage under LRET for the applicable period
JRPP = jurisdictional renewable power percentage for the applicable period
REC_surrendered = eligible renewable energy certificates voluntarily surrendered
REC_onsite = eligible renewable energy certificates issued for onsite generated electricity
EF_RMF3elec = scope 3 residual mix emission factor for electricity
--------------------------------------
*/

VEERG_15_12_1_2__1_UpstreamPurchasedElectricityMarketBased
  =LAMBDA(
    Q_elec, RPP, JRPP, REC_surrendered, REC_onsite, EF_RMF3elec,
    ((Q_elec * (1 - (RPP + JRPP))) - ((REC_surrendered - REC_onsite) * 10 ^ -3)) * EF_RMF3elec * 10 ^ -3
  );

VEERG_15_12_1_2__1_UpstreamPurchasedElectricityMarketBasedVariation
  =LAMBDA(
    Q_elec, RPP, JRPP, REC_surrendered, REC_onsite, EF_RMF3elec,
    ((Q_elec * (1 - (RPP + JRPP))) - ((REC_surrendered - REC_onsite) * 10 ^ 3)) * EF_RMF3elec * 10 ^ -3
  );

