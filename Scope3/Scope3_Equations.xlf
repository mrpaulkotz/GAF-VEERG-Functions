/*
--------------------------------------
VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents
Emissions from purchased fertiliser components
E
t CO2e
E=\sum\nolimits_f\sum\nolimits_c\sum\nolimits_j\left((F_{cf}\times TM_{jf})/100\times EF_c\right)
F_cf = fraction of component c contained within the inorganic fertiliser f
TM_jf = quantity of inorganic fertiliser type f purchased and applied to production system j
EF_c = emission factor for the production of component c
--------------------------------------
*/

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents
  =LAMBDA(
    F_cf, TM_jf, EF_c,
    ((F_cf * TM_jf) / 100) * EF_c
  );

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponentsVariation
  =LAMBDA(
    F_cf, TM_jf, EF_c,
    (F_cf * TM_jf) * EF_c * 10^-3
  );

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_Title
  =LAMBDA("Emissions from purchased fertiliser components");

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_Variable
  =LAMBDA("E");

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_Unit
  =LAMBDA("t CO2e");

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_Source
  =LAMBDA("VEERG 2026: 15.4.1.1, Equation (2)");

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_NIRReference
  =LAMBDA("");

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_LatexEquation
  =LAMBDA("E=\sum\nolimits_f\sum\nolimits_c\sum\nolimits_j\left(\frac{F_{cf}\times TM_{jf}}{100}\times EF_c\right)");

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_LatexEquationVariation
  =LAMBDA("E=\sum\nolimits_f\sum\nolimits_c\sum\nolimits_j\left(F_{cf}\times TM_{jf}\times EF_c\right)\times 10^{-3}");

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "F_cf", "fraction of component c contained within the inorganic fertiliser f", "wt%", "Input";
          "TM_jf", "quantity of inorganic fertiliser type f purchased and applied to production system j", "kg", "Input";
          "EF_c", "emission factor for the production of component c", "kg CO2e/kg component", "Constant";
          "c", "fertiliser component", "", "Input";
          "f", "inorganic fertiliser type", "", "Input";
          "j", "production system", "", "Input"
        }, r, c)
      )
    )
  );

VEERG_15_4_1_1__2_EmissionsFromPurchasedFertiliserComponents_Variation
  =LAMBDA("VARIATION ON SOURCE: removes division by 100 for F_cf, treating F_cf as fraction instead of percent because it is a fraction in scope 1 equations. Convert kg to tonnes by mutiplying by 10^-3.");




