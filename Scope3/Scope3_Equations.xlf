/*
--------------------------------------
VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock
Total emissions from purchased livestock
E
t CO2e
E=\sum\nolimits_c\sum\nolimits_o\left(N_{co}\times W_{co}\times EF_{co}\right)\times 10^{-3}
N_co = number of animals purchased in livestock type c from origin o
W_co = average liveweight of purchased livestock at point of purchase
EF_co = emission factor per livestock type and origin
--------------------------------------
*/

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock
  =LAMBDA(
    N_co, W_co, EF_co,
    (N_co * W_co * EF_co) * 10 ^ -3
  );

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock_Title
  =LAMBDA("Total emissions from purchased livestock");

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock_Variable
  =LAMBDA("E");

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock_Unit
  =LAMBDA("t CO2e");

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock_Source
  =LAMBDA("VEERG 2026: 15.1.1.1, Equation (1)");

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock_NIRReference
  =LAMBDA("");

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock_LatexEquation
  =LAMBDA("E=\sum\nolimits_c\sum\nolimits_o\left(N_{co}\times W_{co}\times EF_{co}\right)\times 10^{-3}");

VEERG_15_1_1_1__1_EmissionsFromPurchasedLivestock_Arguments
  =LAMBDA(
    MAKEARRAY(5, 4,
      LAMBDA(r,c,
        INDEX({
          "N_co", "number of animals purchased in livestock type c from origin o", "head", "Input";
          "W_co", "average liveweight of purchased livestock at point of purchase", "kg/head", "Input";
          "EF_co", "emission factor per livestock type and origin", "kg CO2e/kg", "Constant";
          "c", "livestock type", "", "Input";
          "o", "origin", "", "Input"
        }, r, c)
      )
    )
  );

