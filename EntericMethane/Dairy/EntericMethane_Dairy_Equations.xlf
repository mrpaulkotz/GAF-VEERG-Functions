VEERG_3_3_1_1__6_MetabolisabilityOfDiet_LatexEquation
  =LAMBDA("qm_j=0.795\times (DMD_j\times 100)-0.0014");

VEERG_3_3_1_1__6_MetabolisabilityOfDiet_LatexEquationVariation
  =LAMBDA("qm_j=0.00795\times (DMD_j\times 100)-0.0014");

VEERG_3_3_1_1__6_MetabolisabilityOfDiet_Arguments
  =LAMBDA(
    MAKEARRAY(1, 4,
