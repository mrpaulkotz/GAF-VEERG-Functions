/*
============================================================================
3.3: Enteric Methane - Dairy Cattle
============================================================================
3.3.1.1 Method 1 - Enteric Dairy Cattle
============================================================================
*/

/*
--------------------------------------
VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation
Total annual methane production from enteric fermentation in dairy cattle
E_enteric
t CH4
E_{enteric}=((N_{j=1,2,4}\times M_{j=1,2,4}\times D_{j=1,2,4})+(N_{j=3,5}\times M_{j=3,5}\times D_{j=3,5})+(N_{j=3,5}\times MPW_{ENTERIC,j=3,5}\times D_{j=3,5}))\times 10^{-3}
N_j124 = number of dairy cattle in classes j=1,2,4 (head)
M_j124 = daily enteric methane production for classes j=1,2,4 (kg CH4/head/day)
D_j124 = duration of stay on the farm for classes j=1,2,4 (days)
N_j35 = number of dairy cattle in classes j=3,5 (head)
M_j35 = daily enteric methane production for classes j=3,5 (kg CH4/head/day)
D_j35 = duration of stay on the farm for classes j=3,5 (days)
MPW_ENTERIC_j35 = daily methane production for pre-weaned heifer and bull calves (kg CH4/head/day)
--------------------------------------
*/

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation
  =LAMBDA(
    N_j124, M_j124, D_j124, N_j35, M_j35, D_j35, MPW_ENTERIC_j35,
    ((N_j124 * M_j124 * D_j124) + (N_j35 * M_j35 * D_j35) + (N_j35 * MPW_ENTERIC_j35 * D_j35)) * 10 ^ -3
  );

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentationVariation
  =LAMBDA(
    N_j124, M_j124, D_j124, N_j35, M_j35, D_j35, DPW_j35, MPW_ENTERIC_j35,
    ((N_j124 * M_j124 * D_j124) + (N_j35 * M_j35 * D_j35) + (N_j35 * MPW_ENTERIC_j35 * DPW_j35)) * 10 ^ -3
  );

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_Title
  =LAMBDA("Total annual methane production from enteric fermentation in dairy cattle");

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_Variable
  =LAMBDA("E_enteric");

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_Unit
  =LAMBDA("t CH4");

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_Source
  =LAMBDA("VEERG 2026: 3.3.1.1, Equation (1)");

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_NIRReference
  =LAMBDA("");

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_LatexEquation
  =LAMBDA("E_{enteric}=\sum\nolimits_j((N_{j=1,2,4}\times M_{j=1,2,4}\times D_{j=1,2,4})+(N_{j=3,5}\times M_{j=3,5}\times D_{j=3,5})+(N_{j=3,5}\times MPW_{ENTERIC,j=3,5}\times D_{j=3,5}))\times 10^{-3}");

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_LatexEquationVariation
  =LAMBDA("E_{enteric}=\sum\nolimits_j((N_{j=1,2,4}\times M_{j=1,2,4}\times D_{j=1,2,4})+(N_{j=3,5}\times M_{j=3,5}\times D_{j=3,5})+(N_{j=3,5}\times MPW_{ENTERIC,j=3,5}\times DPW_{j=3,5}))\times 10^{-3}");

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_Arguments
  =LAMBDA(
    MAKEARRAY(8, 4,
      LAMBDA(r,c,
        INDEX({
          "N_j124", "number of dairy cattle in classes j=1,2,4", "head", "Input";
          "M_j124", "daily enteric methane production for classes j=1,2,4", "kg CH4/head/day", "Calculated from 3.3.1.1 (2)";
          "D_j124", "duration of stay on the farm for classes j=1,2,4", "days", "Input";
          "N_j35", "number of dairy cattle in classes j=3,5", "head", "Input";
          "M_j35", "daily enteric methane production for weaned classes j=3,5", "kg CH4/head/day", "Calculated from 3.3.1.1 (2)";
          "D_j35", "duration of stay on the farm for weaned classes j=3,5", "days", "Input";
          "DPW_j35", "duration of stay on the farm for pre-weaned heifer and bull calves", "days", "Input";
          "MPW_ENTERIC_j35", "daily methane production for pre-weaned heifer and bull calves", "kg CH4/head/day", "Constant"

        }, r, c)
      )
    )
  );

VEERG_3_3_1_1__1_TotalAnnualMethaneFromEntericFermentation_Variation
  =LAMBDA("VARIATION ON SOURCE: Added 'DPW' variable to allow for a separate handling of pre-weaned duration.");

/*
--------------------------------------
VEERG_3_3_1_1__2_DailyEntericMethaneProduction
Daily production of enteric methane
M_j
kg CH4/head/day
M_j=20.7\times I_j\times 10^{-3}
I_j = dry matter feed intake (kg DM/head/day)
--------------------------------------
*/

VEERG_3_3_1_1__2_DailyEntericMethaneProduction
  =LAMBDA(
    I_j,
    20.7 * I_j * 10 ^ -3
  );

VEERG_3_3_1_1__2_DailyEntericMethaneProduction_Title
  =LAMBDA("Daily production of enteric methane");

VEERG_3_3_1_1__2_DailyEntericMethaneProduction_Variable
  =LAMBDA("M_j");

VEERG_3_3_1_1__2_DailyEntericMethaneProduction_Unit
  =LAMBDA("kg CH4/head/day");

VEERG_3_3_1_1__2_DailyEntericMethaneProduction_Source
  =LAMBDA("VEERG 2026: 3.3.1.1, Equation (2)");

VEERG_3_3_1_1__2_DailyEntericMethaneProduction_NIRReference
  =LAMBDA("Charmley et al. (2015)");

VEERG_3_3_1_1__2_DailyEntericMethaneProduction_LatexEquation
  =LAMBDA("M_j=20.7\times I_j\times 10^{-3}");

VEERG_3_3_1_1__2_DailyEntericMethaneProduction_Arguments
  =LAMBDA(
    MAKEARRAY(1, 4,
      LAMBDA(r,c,
        INDEX({
          "I_j", "dry matter feed intake", "kg DM/head/day", "Calculated from 3.3.1.1 (3)"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_3_3_1_1__3_DryMatterFeedIntake
Feed intake
I_j
kg DM/head/day
I_j=(1.185+0.00454\times W_j-0.0000026\times W_j^2+0.315\times LWG_j)^2\times MR_j+MI_j
W_j = liveweight (kg)
LWG_j = liveweight gain (kg/head/day)
MR_j = increase in metabolic rate when producing milk (fraction)
MI_j = additional intake required for milk production (kg DM/head/day)
--------------------------------------
*/

VEERG_3_3_1_1__3_DryMatterFeedIntake
  =LAMBDA(
    W_j, LWG_j, MR_j, MI_j,
    (1.185 + 0.00454 * W_j - 0.0000026 * W_j ^ 2 + 0.315 * LWG_j) ^ 2 * MR_j + MI_j
  );

VEERG_3_3_1_1__3_DryMatterFeedIntake_Title
  =LAMBDA("Feed intake");

VEERG_3_3_1_1__3_DryMatterFeedIntake_Variable
  =LAMBDA("I_j");

VEERG_3_3_1_1__3_DryMatterFeedIntake_Unit
  =LAMBDA("kg DM/head/day");

VEERG_3_3_1_1__3_DryMatterFeedIntake_Source
  =LAMBDA("VEERG 2026: 3.3.1.1, Equation (3)");

VEERG_3_3_1_1__3_DryMatterFeedIntake_NIRReference
  =LAMBDA("");

VEERG_3_3_1_1__3_DryMatterFeedIntake_LatexEquation
  =LAMBDA("I_j=(1.185+0.00454\times W_j-0.0000026\times W_j^2+0.315\times LWG_j)^2\times MR_j+MI_j");

VEERG_3_3_1_1__3_DryMatterFeedIntake_Arguments
  =LAMBDA(
    MAKEARRAY(4, 4,
      LAMBDA(r,c,
        INDEX({
          "W_j", "liveweight", "kg", "Input";
          "LWG_j", "liveweight gain", "kg/head/day", "Input";
          "MR_j", "increase in metabolic rate when producing milk", "fraction", "Constant";
          "MI_j", "additional intake required for milk production", "kg DM/head/day", "Calculated from 3.3.1.1 (4)"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction
Additional intake required for milk production
MI_j
kg DM/head/day
MI_j=(MP_j\times 1.03\times NE)/(GEC\times k\times qm_j)
MP_j = milk production (L/head/day)
NE = net energy (MJ net energy/kg milk)
GEC = gross energy content (MJ/kgDM)
k = efficiency of metabolizable energy use for milk production (fraction)
qm_j = metabolisability of the diet (fraction)
--------------------------------------
*/

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction
  =LAMBDA(
    MP_j, NE, GEC, k, qm_j,
    (MP_j * 1.03 * NE) / (GEC * k * qm_j)
  );

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_Title
  =LAMBDA("Additional intake required for milk production");

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_Variable
  =LAMBDA("MI_j");

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_Unit
  =LAMBDA("kg DM/head/day");

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_Source
  =LAMBDA("VEERG 2026: 3.3.1.1, Equation (4)");

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_NIRReference
  =LAMBDA("");

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_LatexEquation
  =LAMBDA("MI_j=\frac{MP_j\times 1.03\times NE}{GEC\times k\times qm_j}");

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_Arguments
  =LAMBDA(
    MAKEARRAY(7, 4,
      LAMBDA(r,c,
        INDEX({
          "MPU", "input milk production unit", "", "Input";
          "MP_j", "milk production (if input as litres of milk)", "L/head/day", "Input";
          "MP_j", "milk production (if input as milk solids)", "L/head/day", "Calculated from 3.3.1.1 (5)";
          "NE", "net energy", "MJ net energy/kg milk", "Constant";
          "GEC", "gross energy content", "MJ/kgDM", "Constant";
          "k", "efficiency of metabolizable energy use for milk production", "fraction", "Constant";
          "qm_j", "metabolisability of the diet", "fraction", "Calculated from 3.3.1.1 (6)"
        }, r, c)
      )
    )
  );

VEERG_3_3_1_1__4_AdditionalIntakeForMilkProduction_Variation
  =LAMBDA("VARATION ON SOURCE: Added milk production unit variable to allow for use of either milk solids or litres of milk.");

/*
--------------------------------------
VEERG_3_3_1_1__5_MilkProductionFromMilkSolids
Milk production converted from milk solids
MP_j
L/head/day
MP_j=MS_j/(0.01\times (FC_j+PC_j))
MS_j = daily production of milk solids (kg MS/head/day)
FC_j = fat content in fat and protein corrected milk (per cent)
PC_j = protein content in fat and protein corrected milk (per cent)
--------------------------------------
*/

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids
  =LAMBDA(
    MS_j, FC_j, PC_j,
    MS_j / (0.01 * (FC_j + PC_j))
  );

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_Title
  =LAMBDA("Milk production converted from milk solids");

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_Variable
  =LAMBDA("MP_j");

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_Unit
  =LAMBDA("L/head/day");

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_Source
  =LAMBDA("VEERG 2026: 3.3.1.1, Equation (5)");

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_NIRReference
  =LAMBDA("");

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_LatexEquation
  =LAMBDA("MP_j=\frac{MS_j}{0.01\times (FC_j+PC_j)}");

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_Arguments
  =LAMBDA(
    MAKEARRAY(4, 4,
      LAMBDA(r,c,
        INDEX({
          "MPU", "input milk production unit", "", "Input";
          "MS_j", "daily production of milk solids", "kg MS/head/day", "Input";
          "FC_j", "fat content in fat and protein corrected milk", "per cent", "Constant";
          "PC_j", "protein content in fat and protein corrected milk", "per cent", "Constant"
        }, r, c)
      )
    )
  );

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_Arguments_Method2
  =LAMBDA(
    MAKEARRAY(4, 4,
      LAMBDA(r,c,
        INDEX({
          "MPU", "milk production unit", "", "Input";
          "MS_j", "daily production of milk solids", "kg MS/head/day", "Input";
          "FC_j", "fat content in fat and protein corrected milk", "per cent", "Input";
          "PC_j", "protein content in fat and protein corrected milk", "per cent", "Input"
        }, r, c)
      )
    )
  );

VEERG_3_3_1_1__5_MilkProductionFromMilkSolids_Variation
  =LAMBDA("VARATION ON SOURCE: Added milk production unit variable to allow for use of either milk solids or litres of milk. Converted input FC and PC percent to integer.");

/*
--------------------------------------
VEERG_3_3_1_1__6_MetabolisabilityOfDiet
Metabolisability of diet
qm_j
fraction
qm_j=0.795\times (DMD_j\times 100)-0.0014
DMD_j = dry matter digestibility expressed as a fraction
--------------------------------------
*/

VEERG_3_3_1_1__6_MetabolisabilityOfDiet
  =LAMBDA(
    DMD_j,
    0.795 * (DMD_j * 100) - 0.0014
  );

VEERG_3_3_1_1__6_MetabolisabilityOfDietVariation
  =LAMBDA(
    DMD_j,
    0.00795 * (DMD_j * 100) - 0.0014
  );


VEERG_3_3_1_1__6_MetabolisabilityOfDiet_Title
  =LAMBDA("Metabolisability of diet");

