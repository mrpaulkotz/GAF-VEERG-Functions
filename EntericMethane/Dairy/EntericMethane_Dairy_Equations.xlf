  =LAMBDA("qm_j");

VEERG_3_3_1_1__6_MetabolisabilityOfDiet_Unit
  =LAMBDA("fraction");

VEERG_3_3_1_1__6_MetabolisabilityOfDiet_Source
  =LAMBDA("VEERG 2026: 3.3.1.1, Equation (6)");

