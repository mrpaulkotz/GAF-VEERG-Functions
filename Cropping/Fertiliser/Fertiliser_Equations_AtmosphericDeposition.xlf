VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser_Title
  =LAMBDA("Mass of nitrogen volatilised from inorganic fertiliser applied to production system");

VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser_Variable
  =LAMBDA("M_volinorganicjf");

VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser_Unit
