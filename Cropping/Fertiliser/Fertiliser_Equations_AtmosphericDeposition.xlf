/*
======================================
5: Fertiliser Use
======================================
5.4 Inorganic fertiliser atmospheric deposition
======================================
*/

/* 
--------------------------------------
VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions
Nitrous oxide emissions from atmospheric deposition from all inorganic fertiliser types f and all production systems j
E_adinorganic
t N2O
E_{ad,inorganic}=\sum_{j}\sum_{f}((M_{vol,inorganic,jf}\times EF_{N2O,j})\times C_{N2O}\times 10^{-3})
M_volinorganicjf
EF_N2Oj
C_N2O
j
f
--------------------------------------
*/

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions
  =LAMBDA(
    M_volinorganicjf, EF_N2Oj, C_N2O,
    (M_volinorganicjf * EF_N2Oj) * C_N2O * 10 ^ -3
  );

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions_Title
  =LAMBDA("Nitrous oxide emissions from atmospheric deposition from all inorganic fertiliser types f and all production systems j");

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions_Variable
  =LAMBDA("E_adinorganic");

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions_Unit
  =LAMBDA("t N2O");

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions_Source
  =LAMBDA("VEERG 2026: 5.4.1.1, Equation (1)");

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions_NIRReference
  =LAMBDA("");

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions_LatexEquation
  =LAMBDA("E_{ad,inorganic}=\sum\nolimits_{j}\sum\nolimits_{f}((M_{vol,inorganic,jf}\times EF_{N2O,j})\times C_{N2O}\times 10^{-3})");

VEERG_5_4_1_1__1_InorganicFertiliserAtmosphericDepositionN2OEmissions_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4, 
      LAMBDA(r,c, 
        INDEX({
          "M_volinorganicjf","mass of nitrogen volatilised from inorganic fertiliser applied to production system", "kg N", "Calculated from 5.4.1.1 (2)";
          "EF_N2Oj","emission factor for atmospheric deposition", "kg N2O-N/kg N", "Constant";
          "C_N2O","factor to convert elemental mass of nitrous oxide to molecular mass", "", "Constant";
          "j","Production system", "", "Input";
          "ir","irrigation method", "", "Input";
          "r","rainfall region", "", "Input"
        }, r, c)
      )
    )
  );

/* 
--------------------------------------
VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser
Mass of nitrogen volatilised from inorganic fertiliser applied to production system
M_volinorganicjf
kg N
M_{vol,inorganic,jf}={MN}_{jf}\times FracGASF_{f}
MN_jf
FracGASF_f
j
f
--------------------------------------
