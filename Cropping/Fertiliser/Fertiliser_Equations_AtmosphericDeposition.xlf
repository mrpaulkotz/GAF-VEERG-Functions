VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser_Source
  =LAMBDA("VEERG 2026: 5.4.1.1, Equation (2)");

VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser_NIRReference
  =LAMBDA("");

VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser_LatexEquation
  =LAMBDA("M_{vol,inorganic,jf}={MN}_{jf}\times FracGASF_{f}");

VEERG_5_4_1_1__2_MassOfNitrogenVolatilisedFromInorganicFertiliser_Arguments
  =LAMBDA(
    MAKEARRAY(2, 4, 
      LAMBDA(r,c, 
        INDEX({
          "MN_jf","mass of nitrogen in inorganic fertiliser applied", "kg N", "Calculated from 5.1.1.1 (2)";
          "FracGASF_f","fraction of inorganic fertiliser that volatilises", "(kg NH3-N + NOx-N)/kg N", "Constant"
        }, r, c)
      )
    )
  );


