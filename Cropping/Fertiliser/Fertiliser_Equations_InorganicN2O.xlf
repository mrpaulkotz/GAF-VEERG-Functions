/* 
--------------------------------------
VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions
Nitrous oxide emissions from the application of all inorganic fertiliser types f to all production systems j
E_N2O
t N2O
\sum_{j}\sum_{f}((MN_{jf}\times EF_{j,N2O}\times C_{N2O})\times 10^{-3})
MN_jf
EF_jN2O
C_N2O
j
f
--------------------------------------
*/

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions
  =LAMBDA(
    MN_jf, EF_jN2O, C_N2O,
    (MN_jf * EF_jN2O * C_N2O) * 10 ^ -3
  );

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_Title
  =LAMBDA("Nitrous oxide emissions from the application of all inorganic fertiliser types f to all production systems j");

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_Variable
  =LAMBDA("E_N2O");

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_Unit
  =LAMBDA("t N2O");

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_Source
  =LAMBDA("VEERG 2026: 5.1.1.1, Equation (1)");

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_NIRReference
  =LAMBDA("");

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_LatexEquation
  =LAMBDA("E_{N2O}=\sum_{j}\sum_{f}((MN_{jf}\times EF_{j,N2O}\times C_{N2O})\times 10^{-3})");

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_Arguments
  =LAMBDA(
    MAKEARRAY(7, 3, 
      LAMBDA(r,c, 
        INDEX({
          "MN_jf","mass of nitrogen in inorganic fertiliser type f applied to production system j (kg N)", "Calculated";
          "EF_jN2O","emission factor for nitrous oxide for inorganic fertilisers (kg N2O-N/kg N applied)", "Constant";
          "C_N2O","factor to convert elemental mass of nitrous oxide to molecular mass", "Constant";
          "j","Production system", "Input";
          "f","Inorganic fertiliser type", "Constant";
          "ir", "irrigation method", "Input";
          "z", "rainfall zone", "Input"
        }, r, c)
      )
    )
  );

VEERG_5_1_1_1__1_InorganicFertiliserApplicationN2OEmissions_Arguments_Method2
  =LAMBDA(
    MAKEARRAY(8, 3, 
      LAMBDA(r,c, 
        INDEX({
          "MN_jf","mass of nitrogen in inorganic fertiliser type f applied to production system j (kg N)", "Calculated";
          "EF_jN2O","emission factor for nitrous oxide for inorganic fertilisers (kg N2O-N/kg N applied)", "Lookup";
          "C_N2O","factor to convert elemental mass of nitrous oxide to molecular mass", "Constant";
          "j","Production system", "Input";
          "c","Crop type", "Input";
          "f","Inorganic fertiliser type", "Constant";
          "ir", "irrigation method", "Input";
          "z", "rainfall zone", "Input"
        }, r, c)
      )
    )
  );

