/* 
--------------------------------------
VEERG_5_1_1_2__3_EmissionFactorCotton
Emission factor for nitrous oxide for cotton
EF_fjCottonN2O
kg N2O-N/kg N applied
EF_{fj=cotton,N2O}=\min\left((0.01\times(0.29+0.007\times((e^{(0.037\times N_{fj=cotton})}-1)/N_{fj=cotton})))\times 10^{-2},0.0183\right)
N_fjCotton
f
--------------------------------------
*/

VEERG_5_1_1_2__3_EmissionFactorCotton
  =LAMBDA(
    N_fjCotton,
    (0.01 * (0.29 + (  (0.007 * (EXP(0.037 * N_fjCotton) - 1)) / N_fjCotton  ) )) * 10 ^ -2
  );

VEERG_5_1_1_2__3_EmissionFactorCotton_Title
  =LAMBDA("Emission factor for nitrous oxide for cotton");

VEERG_5_1_1_2__3_EmissionFactorCotton_Variable
  =LAMBDA("EF_fjCottonN2O");

VEERG_5_1_1_2__3_EmissionFactorCotton_Unit
  =LAMBDA("kg N2O-N/kg N applied");

VEERG_5_1_1_2__3_EmissionFactorCotton_Source
  =LAMBDA("VEERG 2026: 5.1.1.2, Equation (3)");

VEERG_5_1_1_2__3_EmissionFactorCotton_NIRReference
  =LAMBDA("");

VEERG_5_1_1_2__3_EmissionFactorCotton_LatexEquation
  =LAMBDA("EF_{fj=cotton,N2O}=(0.01 \times (0.29 + \frac{0.007(e^{0.037 \times N_{fj=cotton}}-1)}{N_{fj=cotton}})) \times 10^{-2}
");

VEERG_5_1_1_2__3_EmissionFactorCotton_Arguments
  =LAMBDA(
    MAKEARRAY(2, 3, 
      LAMBDA(r,c, 
        INDEX({
          "N_fjCotton","application rate of inorganic fertiliser type f in the cotton crop (kg N/ha)", "Input";
          "f","Inorganic fertiliser type", "Constant"
        }, r, c)
      )
    )
  );

