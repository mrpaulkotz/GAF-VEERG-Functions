  =LAMBDA("t CH4");

VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues_Source
  =LAMBDA("VEERG 2026: 6.4.1.1, Equation (1)");

VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues_NIRReference
  =LAMBDA("");

VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues_LatexEquation
  =LAMBDA("E_{CH4}=\sum_{c}(M_{burn,c}\times CC_{c}\times EF_{CH4}\times C_{CH4}\times 10^{-3})");

VEERG_6_4_1_1__1__MethaneEmissionsFromBurningOfCropResidues_Arguments
  =LAMBDA(
    MAKEARRAY(5, 2,
      LAMBDA(r,c,
