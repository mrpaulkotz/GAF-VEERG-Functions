/* 
--------------------------------------
VEERG_6_4_1_1__3__MassOfCropResidueBurnt
Mass of residue of crop c burnt
Mburnc
kg
M_{burn,c}=P_{c}\times R_{AGc}\times S_{c}\times DM_{c}\times Z_{c}\times F_{c}
Pc = annual production of crop type c (kg)
RAGc = residue to crop ratio of crop type c (kg crop residue/kg crop)
Sc = fraction of residues of crop type c remaining at burning (dimensionless)
DMc = dry matter content of crop type c (kg dry weight/kg crop residue)
Zc = burning efficiency (ratio of fuel burnt to fuel load) of crop type c (dimensionless)
Fc = fraction of the annual production of crop type c that is burnt (dimensionless)
c = Crop type
--------------------------------------
*/

VEERG_6_4_1_1__3__MassOfCropResidueBurnt
  =LAMBDA(
    Pc, RAGc, Sc, DMc, Zc, Fc,
    Pc * RAGc * Sc * DMc * Zc * Fc
  );

