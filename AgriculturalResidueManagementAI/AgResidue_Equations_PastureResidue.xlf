/* 
--------------------------------------
VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues
Nitrous oxide emissions from the return of pasture residues from all pasture types to the soil
EN2O
t N2O
E_{N2O}=\sum_{p}\left(M_p\times EF_{Ni}\times C_{N2O}\times{10}^{-3}\right)
Mp = mass of nitrogen in pasture p residues returned to the soil (kg N)
EFNi = emission factor for crop residues returned to the soil in climate zone i (kg N2O-N/kg N)
CN2O = factor to convert elemental mass of nitrous oxide to molecular mass (dimensionless)
p = Pasture type
i = Climate zone
--------------------------------------
*/

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues
  =LAMBDA(
    M_p, EF_Ni, C_N2O,
    (M_p * EF_Ni) * C_N2O * 10^(-3)
  );

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues_Title
  =LAMBDA("Nitrous oxide emissions from the return of pasture residues from all pasture types to the soil");

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues_Variable
  =LAMBDA("EN2O");

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues_Unit
  =LAMBDA("t N2O");

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues_Source
  =LAMBDA("VEERG 2026: 6.2.1.1, Equation (1)");

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues_NIRReference
  =LAMBDA("");

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues_LatexEquation
  =LAMBDA("E_{N2O}=\sum\nolimits_p\left(M_p\times EF_{Ni}\right)\times C_{N2O}\times{10}^{-3}");

VEERG_6_2_1_1__1__NitrousOxideEmissionsFromPastureResidues_Arguments
  =LAMBDA(
    MAKEARRAY(5, 4, 
      LAMBDA(r,c, 
        INDEX({
          "M_p","mass of nitrogen in pasture p residues returned to the soil", "kg N", "Calculated from 6.2.1.1 (2)";
          "EF_Ni","emission factor for crop residues returned to the soil in climate zone i", "kg N2O-N/kg N", "Constant";
          "C_N2O","factor to convert elemental mass of nitrous oxide to molecular mass", "dimensionless", "Constant";
          "p","Pasture type", "", "Input";
          "i","Wet or dry climate zone", "", "Input"
        }, r, c)
      )
    )
  );

/* 
--------------------------------------
VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues
Mass of nitrogen in pasture residues returned to the soil
Mp
kg N
M_p = (A_p ×(Y_p \times 10^{-3}) \times (1- FFOD_p) \times NC_{AGp}) + (A_p \times (Y_p \times 10^{-3})\times R_{BGp} \times NC_{BGp})
A_p = area of pasture renewed or removed (ha)
Yp = average yield of pasture crop (t DM/ha)
NCAGp = N content of above-ground pasture residue (kg N/kg DM)
R_BGp = below-ground residue to above-ground residue ratio for pasture crop (dimensionless)
NC_BGp = N content of below-ground pasture crop residue (kg N/kg DM)
FFODp = fraction of pasture yield that is removed (dimensionless)
p = Pasture type
--------------------------------------
*/

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues
  =LAMBDA(
    A_p, Y_p, FFOD_p, NC_AGp, R_BGp, NC_BGp,
    (A_p * (Y_p * 10^(-3)) * (1 - FFOD_p) * NC_AGp) + (A_p * (Y_p * 10^(-3)) * R_BGp * NC_BGp)
  );

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues_Title
  =LAMBDA("Mass of nitrogen in pasture residues returned to the soil");

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues_Variable
  =LAMBDA("Mp");

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues_Unit
  =LAMBDA("kg N");

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues_Source
  =LAMBDA("VEERG 2026: 6.2.1.1, Equation (2)");

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues_NIRReference
  =LAMBDA("");

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues_LatexEquation
  =LAMBDA("M_p = (A_p \times (Y_p \times 10^{-3}) \times (1- FFOD_p) \times NC_{AGp}) + (A_p \times (Y_p \times 10^{-3})\times R_{BGp} \times NC_{BGp})");

VEERG_6_2_1_1__2__MassOfNitrogenInPastureResidues_Arguments
  =LAMBDA(
    MAKEARRAY(7, 4, 
      LAMBDA(r,c, 
        INDEX({
          "A_p","area of pasture renewed or removed", "ha", "Input";
          "Y_p","average yield of pasture crop", "t DM/ha", "Constant";
          "NC_AGp","N content of above-ground pasture residue", "kg N/kg DM", "Constant";
          "R_BGp","below-ground residue to above-ground residue ratio for pasture crop", "dimensionless", "Constant";
          "NC_BGp","N content of below-ground pasture crop residue", "kg N/kg DM", "Constant";
          "FFOD_p","fraction of pasture yield that is removed", "dimensionless", "Constant";
          "p","Pasture type", "", "Input"
        }, r, c)
      )
    )
  );


