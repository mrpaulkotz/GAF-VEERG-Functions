VEERG_4_3_1_3__3a_TotalAnnualNitrogenExcretedGreaterThanOneYear_LatexEquation
  =LAMBDA("AE_{j=1,2,4}=N_{j=1,2,4}\times NE_{j=1,2,4}\times 365");

VEERG_4_3_1_3__3a_TotalAnnualNitrogenExcretedGreaterThanOneYear_Arguments
  =LAMBDA(
