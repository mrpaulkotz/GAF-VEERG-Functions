/*
--------------------------------------
VEERG_4_3_1_3__6_NitrogenRetainedByBody
Amount of nitrogen retained by the body
NR_j
kg N/head/day
NR_j=(((0.032\times MP_j\times 1.03)/6.38)+((0.212-0.008\times (L_j-2)-((0.140-0.008\times (L_j-2))/(1+EXP(-6\times (Z_j-0.4)))))\times (LWG_j\times 0.92)))\times (1/6.25)
MP_j = milk production (L/head/day)
L_j = intake relative to maintenance
Z_j = relative size
LWG_j = liveweight gain (kg/day)
--------------------------------------
*/

VEERG_4_3_1_3__6_NitrogenRetainedByBody
  =LAMBDA(
    MP_j, L_j, Z_j, LWG_j,
    (((0.032 * MP_j * 1.03) / 6.38) + ((0.212 - 0.008 * (L_j - 2) - ((0.140 - 0.008 * (L_j - 2)) / (1 + EXP(-6 * (Z_j - 0.4))))) * (LWG_j * 0.92))) * (1 / 6.25)
  );

VEERG_4_3_1_3__6_NitrogenRetainedByBody_Title
  =LAMBDA("Amount of nitrogen retained by the body");

VEERG_4_3_1_3__6_NitrogenRetainedByBody_Variable
  =LAMBDA("NR_j");

VEERG_4_3_1_3__6_NitrogenRetainedByBody_Unit
  =LAMBDA("kg N/head/day");

VEERG_4_3_1_3__6_NitrogenRetainedByBody_Source
  =LAMBDA("VEERG 2026: 4.3.1.3, Equation (6)");

VEERG_4_3_1_3__6_NitrogenRetainedByBody_NIRReference
  =LAMBDA("");

VEERG_4_3_1_3__6_NitrogenRetainedByBody_LatexEquation
  =LAMBDA("NR_j=(((0.032\times MP_j\times 1.03)/6.38)+((0.212-0.008\times (L_j-2)-((0.140-0.008\times (L_j-2))/(1+e^{-6\times (Z_j-0.4)})))\times (LWG_j\times 0.92)))\times (1/6.25)");

VEERG_4_3_1_3__6_NitrogenRetainedByBody_Arguments
  =LAMBDA(
    MAKEARRAY(4, 2,
      LAMBDA(r,c,
        INDEX({
          "MP_j", "milk production (L/head/day)";
          "L_j", "intake relative to maintenance";
          "Z_j", "relative size";
          "LWG_j", "liveweight gain (kg/day)"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_3_1_3__7_IntakeRelativeToMaintenance
Intake relative to maintenance
L_j
ratio
L_j=I_j/((1.185+0.00454\times W_j-0.0000026\times W_j^2)^2\times MR_j+MI_j)
I_j = dry matter intake (kgDM/head/day)
W_j = liveweight (kg)
MR_j = increase in metabolic rate when producing milk
MI_j = additional intake required for milk production (kgDM/head/day)
--------------------------------------
*/

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance
  =LAMBDA(
    I_j, W_j, MR_j, MI_j,
    I_j / (((1.185 + 0.00454 * W_j - 0.0000026 * W_j ^ 2) ^ 2 * MR_j) + MI_j)
  );

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance_Title
  =LAMBDA("Intake relative to maintenance");

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance_Variable
  =LAMBDA("L_j");

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance_Unit
  =LAMBDA("ratio");

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance_Source
  =LAMBDA("VEERG 2026: 4.3.1.3, Equation (7)");

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance_NIRReference
  =LAMBDA("");

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance_LatexEquation
  =LAMBDA("L_j=I_j/((1.185+0.00454\times W_j-0.0000026\times W_j^2)^2\times MR_j+MI_j)");

VEERG_4_3_1_3__7_IntakeRelativeToMaintenance_Arguments
  =LAMBDA(
    MAKEARRAY(4, 2,
      LAMBDA(r,c,
        INDEX({
          "I_j", "dry matter intake (kgDM/head/day)";
          "W_j", "liveweight (kg)";
          "MR_j", "increase in metabolic rate when producing milk";
          "MI_j", "additional intake required for milk production (kgDM/head/day)"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_3_1_3__8_RelativeSize
Relative size
Z_j
ratio
Z_j=W_j/WR_j
W_j = liveweight (kg)
WR_j = reference weight (kg)
--------------------------------------
*/

VEERG_4_3_1_3__8_RelativeSize
  =LAMBDA(
    W_j, WR_j,
    W_j / WR_j
  );

