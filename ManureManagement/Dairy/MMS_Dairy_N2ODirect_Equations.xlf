/*
============================================================================
4.3: Dairy
============================================================================
4.3.1.3 Method 1 - Manure Direct N2O Dairy
============================================================================
*/

/*
--------------------------------------
VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS
Total annual direct nitrous oxide emissions from manure management systems
E_N2Odir
t N2O
E_{N2O,dir}=MN_{jm}\times EF_m\times C_{N2O}\times 10^{-3}
MN_jm = total nitrogen in each MMS for dairy cattle classes (kg N)
EF_m = nitrous oxide emission factor for each MMS (kg N2O-N/kg N deposited)
C_N2O = factor to convert elemental mass of N2O to molecular mass
--------------------------------------
*/

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS
  =LAMBDA(
    MN_jm, EF_m, C_N2O,
    MN_jm * EF_m * C_N2O * 10 ^ -3
  );

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Title
  =LAMBDA("Total annual direct nitrous oxide emissions from manure management systems");

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Variable
  =LAMBDA("E_N2Odir");

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Unit
  =LAMBDA("t N2O");

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Source
  =LAMBDA("VEERG 2026: 4.3.1.3, Equation (1)");

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_NIRReference
  =LAMBDA("");

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_LatexEquation
  =LAMBDA("E_{N2O,dir}=MN_{jm}\times EF_m\times C_{N2O}\times 10^{-3}");

VEERG_4_3_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "MN_jm", "total nitrogen in each MMS for dairy cattle classes (kg N)";
          "EF_m", "nitrous oxide emission factor for each MMS (kg N2O-N/kg N deposited)";
          "C_N2O", "factor to convert elemental mass of N2O to molecular mass"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_3_1_3__2_TotalNitrogenInEachMMS
Total nitrogen in each MMS
MN_jm
kg N
MN_{jm}=AE_j\times MMS_{jm}
AE_j = total nitrogen excreted by each dairy class (kg N)
MMS_jm = manure management system fraction for class j and system m
--------------------------------------
*/

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS
  =LAMBDA(
    AE_j, MMS_jm,
    AE_j * MMS_jm
  );

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS_Title
  =LAMBDA("Total nitrogen in each MMS");

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS_Variable
  =LAMBDA("MN_jm");

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS_Unit
  =LAMBDA("kg N");

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS_Source
  =LAMBDA("VEERG 2026: 4.3.1.3, Equation (2)");

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS_NIRReference
  =LAMBDA("");

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS_LatexEquation
  =LAMBDA("MN_{jm}=AE_j\times MMS_{jm}");

VEERG_4_3_1_3__2_TotalNitrogenInEachMMS_Arguments
  =LAMBDA(
    MAKEARRAY(2, 2,
      LAMBDA(r,c,
        INDEX({
          "AE_j", "total nitrogen excreted by each dairy class (kg N)";
          "MMS_jm", "manure management system fraction for class j and system m"
        }, r, c)
      )
    )
  );

/*
