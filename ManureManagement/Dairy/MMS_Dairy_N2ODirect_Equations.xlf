VEERG_4_3_1_3__5_CrudeProteinIntakeOfDairyCattle_NIRReference
  =LAMBDA("");

VEERG_4_3_1_3__5_CrudeProteinIntakeOfDairyCattle_LatexEquation
  =LAMBDA("CPI_j=I_j\times CP_j");

VEERG_4_3_1_3__5_CrudeProteinIntakeOfDairyCattle_Arguments
  =LAMBDA(
    MAKEARRAY(2, 2,
      LAMBDA(r,c,
        INDEX({
          "I_j", "dry matter intake (kgDM/head/day)";
          "CP_j", "crude protein content of feed intake (fraction)"
