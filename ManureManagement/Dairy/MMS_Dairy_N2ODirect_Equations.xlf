VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear_Source
  =LAMBDA("VEERG 2026: 4.3.1.3, Equation (3b)");

VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear_NIRReference
  =LAMBDA("");

VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear_LatexEquation
  =LAMBDA("AE_{j=3,5}=(N_{j=3,5}\times NE_{j=3,5}\times 281)+(N_{j=3,5}\times NPW_{j=3,5}\times 84)");

VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "N_j35", "number of dairy cattle in classes j=3,5";
          "NE_j35", "nitrogen excreted by weaned dairy cattle less than one year old (kg N/head/day)";
          "NPW_j35", "nitrogen excreted by pre-weaned calves (kg N/head/day)"
