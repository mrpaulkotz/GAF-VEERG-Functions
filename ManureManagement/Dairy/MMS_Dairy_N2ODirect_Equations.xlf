/*
--------------------------------------
VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear
Total annual nitrogen excreted by dairy cattle <1 year old
AE_j35
kg N
AE_{j=3,5}=(N_{j=3,5}\times NE_{j=3,5}\times 281)+(N_{j=3,5}\times NPW_{j=3,5}\times 84)
N_j35 = number of dairy cattle in classes j=3,5
NE_j35 = nitrogen excreted by weaned dairy cattle <1 year old (kg N/head/day)
NPW_j35 = nitrogen excreted by pre-weaned calves (kg N/head/day)
--------------------------------------
*/

VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear
  =LAMBDA(
    N_j35, NE_j35, NPW_j35,
    (N_j35 * NE_j35 * 281) + (N_j35 * NPW_j35 * 84)
  );

VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear_Title
  =LAMBDA("Total annual nitrogen excreted by dairy cattle less than one year old");

VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear_Variable
  =LAMBDA("AE_j35");

VEERG_4_3_1_3__3b_TotalAnnualNitrogenExcretedLessThanOneYear_Unit
