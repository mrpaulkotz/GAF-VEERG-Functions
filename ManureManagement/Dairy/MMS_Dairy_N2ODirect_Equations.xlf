/*
--------------------------------------
VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear
Nitrogen excreted by dairy cattle >1 year old
NE_j
kg N/head/day
NE_j=(CPI_j/6.25)-NR_j-((1.1\times 10^{-4}\times W_j^{0.75})/6.25)
CPI_j = crude protein intake (kg/head/day)
NR_j = amount of nitrogen retained by the body (kg N/head/day)
W_j = liveweight (kg)
--------------------------------------
*/

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear
  =LAMBDA(
    CPI_j, NR_j, W_j,
    (CPI_j / 6.25) - NR_j - ((1.1 * 10 ^ -4 * W_j ^ 0.75) / 6.25)
  );

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear_Title
  =LAMBDA("Nitrogen excreted by dairy cattle greater than one year old");

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear_Variable
  =LAMBDA("NE_j");

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear_Unit
  =LAMBDA("kg N/head/day");

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear_Source
  =LAMBDA("VEERG 2026: 4.3.1.3, Equation (4)");

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear_NIRReference
  =LAMBDA("");

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear_LatexEquation
  =LAMBDA("NE_j=(CPI_j/6.25)-NR_j-((1.1\times 10^{-4}\times W_j^{0.75})/6.25)");

VEERG_4_3_1_3__4_NitrogenExcretedByDairyCattleGreaterThanOneYear_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "CPI_j", "crude protein intake (kg/head/day)";
          "NR_j", "amount of nitrogen retained by the body (kg N/head/day)";
          "W_j", "liveweight (kg)"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_3_1_3__5_CrudeProteinIntakeOfDairyCattle
Crude protein intake of dairy cattle
CPI_j
kg/head/day
CPI_j=I_j\times CP_j
I_j = dry matter intake (kgDM/head/day)
CP_j = crude protein content of feed intake (fraction)
--------------------------------------
