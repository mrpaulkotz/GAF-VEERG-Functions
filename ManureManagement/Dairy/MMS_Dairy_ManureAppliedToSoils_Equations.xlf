VEERG_4_3_1_8__2_MassOfNitrogenAppliedToSoilsScope3_NIRReference
  =LAMBDA("");

VEERG_4_3_1_8__2_MassOfNitrogenAppliedToSoilsScope3_LatexEquation
  =LAMBDA("MNSoil_{scope3}=\sum\nolimits_{j}\sum\nolimits_{m}(MN_{jm=1-13}\times (1-EF_{m=1-13}-FracGASM_{m=1-13})-MNLeach_{jm})\times (1-PF)");

VEERG_4_3_1_8__2_MassOfNitrogenAppliedToSoilsScope3_Arguments
  =LAMBDA(
    MAKEARRAY(5, 2,
      LAMBDA(r,c,
        INDEX({
          "MN_jm", "total nitrogen in each MMS for dairy cattle classes (kg N)";
          "EF_m", "emission factor for nitrous oxide emissions per MMS (kg N2O-N/kg N)";
          "FracGASM_m", "fraction of N volatilised from MMS";
          "MNLeach_jm", "mass of N lost through leaching and runoff from each MMS (kg N)";
