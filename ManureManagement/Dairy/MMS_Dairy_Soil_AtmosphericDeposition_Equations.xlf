/*
============================================================================
4.3: Dairy
============================================================================
4.3.1.10 Method 1 - Soil Atmospheric Deposition N2O Dairy
============================================================================
*/

/*
--------------------------------------
VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture
Atmospheric deposition emissions from urine and dung deposited on pasture
E_N2Oad
t N2O
E_{N2O,ad}=M_{vol,m=14}\times EF_{N2O}\times C_{N2O}\times 10^{-3}
M_vol_m14 = mass of nitrogen volatilised from urine and faeces deposited on pasture (kg N)
EF_N2O = nitrous oxide emission factor for atmospheric deposition (kg N2O-N/kg N)
C_N2O = factor to convert elemental mass of N2O to molecular mass
--------------------------------------
*/

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture
  =LAMBDA(
    M_vol_m14, EF_N2O, C_N2O,
    M_vol_m14 * EF_N2O * C_N2O * 10 ^ -3
  );

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture_Title
  =LAMBDA("Atmospheric deposition emissions from urine and dung deposited on pasture");

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture_Variable
  =LAMBDA("E_N2Oad");

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture_Unit
  =LAMBDA("t N2O");

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture_Source
  =LAMBDA("VEERG 2026: 4.3.1.10, Equation (1)");

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture_NIRReference
  =LAMBDA("");

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture_LatexEquation
  =LAMBDA("E_{N2O,ad}=M_{vol,m=14}\times EF_{N2O}\times C_{N2O}\times 10^{-3}");

VEERG_4_3_1_10__1_AtmosphericDepositionEmissionsFromUrineAndDungOnPasture_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "M_vol_m14", "mass of nitrogen volatilised from urine and faeces deposited on pasture", "kg N", "Calculated from 4.3.1.10 (2)";
          "EF_N2O", "nitrous oxide emission factor for atmospheric deposition", "kg N2O-N/kg N", "Constant";
          "C_N2O", "factor to convert elemental mass of N2O to molecular mass", "", "Constant";
          "j", "production system", "", "Input";
          "ir", "irrigation method", "", "Input";
          "r", "rainfall region", "", "Input"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture
Mass of nitrogen volatilised from urine and faeces deposited on pasture
M_vol_m14
kg N
M_{vol,m=14}=MN_{jm=14}\times FracGASMsoil
MN_jm14 = mass of nitrogen excreted on pasture, range and paddock for each dairy class (kg N)
FracGASMsoil = fraction of nitrogen volatilised from urine and faeces deposited on pasture ((kg NH3-N + NOx-N)/kg N)
--------------------------------------
*/

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture
  =LAMBDA(
    MN_jm14, FracGASMsoil,
    MN_jm14 * FracGASMsoil
  );

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture_Title
  =LAMBDA("Mass of nitrogen volatilised from urine and faeces deposited on pasture");

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture_Variable
  =LAMBDA("M_vol_m14");

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture_Unit
  =LAMBDA("kg N");

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture_Source
  =LAMBDA("VEERG 2026: 4.3.1.10, Equation (2)");

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture_NIRReference
  =LAMBDA("");

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture_LatexEquation
  =LAMBDA("M_{vol,m=14}=\sum\nolimits_{j}(MN_{jm=14}\times FracGASMsoil)");

VEERG_4_3_1_10__2_MassOfNitrogenVolatilisedOnPasture_Arguments
  =LAMBDA(
    MAKEARRAY(2, 4,
      LAMBDA(r,c,
        INDEX({
          "MN_jm14", "mass of nitrogen excreted on pasture, range and paddock for each dairy class", "kg N", "Calculated from 4.3.1.3 (2)";
          "FracGASMsoil", "fraction of nitrogen volatilised from urine and faeces deposited on pasture", "(kg NH3-N + NOx-N)/kg N)", "Constant"
        }, r, c)
      )
    )
  );
