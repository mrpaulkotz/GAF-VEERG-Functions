/*
============================================================================
4.3: Dairy
============================================================================
4.3.1.6 Method 1 - Manure Leaching And Runoff N2O Dairy
============================================================================
*/

/*
--------------------------------------
VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS
Annual emissions from leaching and runoff from each MMS
E_N2Oleach
t N2O
E_{N2O,leach}=MNLeach_{jm}\times EF_{leach}\times C_{N2O}\times 10^{-3}
MNLeach_jm = mass of N lost through leaching and runoff from each MMS (kg N)
EF_leach = nitrous oxide emission factor for leaching and runoff (kg N2O-N/kg N)
C_N2O = factor to convert elemental mass of N2O to molecular mass
VARIATION OF SOURCE: For Method 1, emissions are estimated only for solid storage (m=4).
--------------------------------------
*/

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS
  =LAMBDA(
    MNLeach_jm, EF_leach, C_N2O,
    (MNLeach_jm * EF_leach * C_N2O) * 10 ^ -3
  );

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Title
  =LAMBDA("Annual emissions from leaching and runoff from each MMS");

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Variable
  =LAMBDA("E_N2Oleach");

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Unit
  =LAMBDA("t N2O");

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Source
  =LAMBDA("VEERG 2026: 4.3.1.6, Equation (1)");

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_NIRReference
  =LAMBDA("");

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_LatexEquation
  =LAMBDA("E_{N2O,leach}=\sum\nolimits_{j}\sum\nolimits_{m=1-13}(MNLeach_{jm}\times EF_{leach}\times C_{N2O})\times 10^{-3}");

VEERG_4_3_1_6__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Arguments
  =LAMBDA(
    MAKEARRAY(3, 4,
      LAMBDA(r,c,
        INDEX({
          "MNLeach_jm", "mass of N lost through leaching and runoff", "kg N", "Calculated from 4.3.1.6 (2)";
          "EF_leach", "nitrous oxide emission factor for leaching and runoff", "kg N2O-N/kg N", "Constant";
          "C_N2O", "factor to convert elemental mass of N2O to molecular mass", "", "Constant"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage
Mass of nitrogen lost to leaching and runoff from solid storage systems
MNLeach_jm4
kg N
MNLeach_{jm=4}=MN_{jm=4}\times FracWET_i\times FracLEACH_MS
MN_jm4 = total nitrogen in solid storage system m=4 (kg N)
FracWET_i = fraction of N available for leaching and runoff
FracLEACH_MS = fraction of N lost through leaching and runoff
--------------------------------------
*/

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage
  =LAMBDA(
    MN_jm4, FracWET_i, FracLEACH_MS,
    MN_jm4 * FracWET_i * FracLEACH_MS
  );

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage_Title
  =LAMBDA("Mass of nitrogen lost to leaching and runoff from solid storage systems");

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage_Variable
  =LAMBDA("MNLeach_jm4");

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage_Unit
  =LAMBDA("kg N");

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage_Source
  =LAMBDA("VEERG 2026: 4.3.1.6, Equation (2)");

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage_NIRReference
  =LAMBDA("");

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage_LatexEquation
  =LAMBDA("MNLeach_{jm=4}=MN_{jm=4}\times FracWET_i\times FracLEACH_{MS}");

VEERG_4_3_1_6__2_MassOfNitrogenLostToLeachingAndRunoffFromSolidStorage_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "MN_jm4", "total nitrogen in solid storage system m=4 (kg N)", "kg N", "Calculated from 4.3.1.3 (2)";
          "FracWET_i", "fraction of N that is available for leaching and runoff from the leaching zone z and irrigation type ir", "fraction", "Constant";
          "FracLEACH_MS", "fraction of N that is lost through leaching and runoff", "fraction", "Constant";
          "z", "location in leaching zone", "", "Input";
          "j", "production system", "", "Input";
          "ir", "irrigation method", "", "Input"
        }, r, c)
      )
    )
  );
