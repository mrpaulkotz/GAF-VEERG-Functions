/*
============================================================================
4.2: Pasture Beef
============================================================================
4.2.1.7 Method 1 - Soil Leaching And Runoff N2O Beef Grazing
============================================================================
*/

/*
--------------------------------------
VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture
Leaching and runoff emissions from urine and dung deposited on pasture
E_N2Oleach
t N2O
E_{N2O,leach}=M_{leach}	imes EF_{leach}	imes C_{N2O}	imes 10^{-3}
M_leach = mass of nitrogen lost to leaching and runoff (kg N)
EF_leach = emission factor for leaching and runoff (kg N2O-N/kg N)
C_N2O = factor to convert elemental mass of N2O to molecular mass
--------------------------------------
*/

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture
  =LAMBDA(
    M_leach, EF_leach, C_N2O,
    M_leach * EF_leach * C_N2O * 10 ^ -3
  );

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture_Title
  =LAMBDA("Leaching and runoff emissions from urine and dung deposited on pasture");

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture_Variable
  =LAMBDA("E_N2Oleach");

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture_Unit
  =LAMBDA("t N2O");

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture_Source
  =LAMBDA("VEERG 2026: 4.2.1.7, Equation (1)");

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture_NIRReference
  =LAMBDA("");

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture_LatexEquation
  =LAMBDA("E_{N2O,leach}=M_{leach}\times EF_{leach}\times C_{N2O}\times 10^{-3}");

VEERG_4_2_1_7__1_LeachingAndRunoffEmissionsFromUrineAndDungOnPasture_Arguments
  =LAMBDA(
    MAKEARRAY(3, 4,
      LAMBDA(r,c,
        INDEX({
          "M_leach", "mass of nitrogen lost to leaching and runoff", "kg N", "Calculated from 4.2.1.7 (2)";
          "EF_leach", "emission factor for leaching and runoff", "kg N2O-N/kg N", "Constant";
          "C_N2O", "factor to convert elemental mass of N2O to molecular mass", "", "Constant"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture
Mass of nitrogen lost to leaching and runoff
M_leach
kg N
M_{leach}=AE\times FracWet\times FracLEACH
AE = total mass of nitrogen excreted on PRP for beef cattle (kg N)
FracWet = fraction of N available for leaching and runoff
FracLEACH = fraction of all N that is lost through leaching and runoff
--------------------------------------
*/

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture
  =LAMBDA(
    AE, FracWet, FracLEACH,
    AE * FracWet * FracLEACH
  );

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture_Title
  =LAMBDA("Mass of nitrogen lost to leaching and runoff");

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture_Variable
  =LAMBDA("M_leach");

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture_Unit
  =LAMBDA("kg N");

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture_Source
  =LAMBDA("VEERG 2026: 4.2.1.7, Equation (2)");

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture_NIRReference
  =LAMBDA("");

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture_LatexEquation
  =LAMBDA("M_{leach}=AE\times FracWet\times FracLEACH");

VEERG_4_2_1_7__2_MassOfNitrogenLostToLeachingAndRunoffOnPasture_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "AE", "total mass of nitrogen excreted on PRP for beef cattle", "kg N", "Calculated from 4.2.1.3 (2)";
          "FracWet", "fraction of N available for leaching and runoff", "fraction", "Constant";
          "FracLEACH", "fraction of all N that is lost through leaching and runoff", "fraction", "Constant";
          "z", "location in leaching zone", "", "Input";
          "j", "production system", "", "Input";
          "ir", "irrigation method", "", "Input"
        }, r, c)
      )
    )
  );

