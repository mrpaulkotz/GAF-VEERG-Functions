VEERG_4_5_1_1__6_Stage2MethaneProduction_LatexEquation
  =LAMBDA("M_{ijm,T=2}=VST_{jm,T=2}\times BO\times MMS_{jm,T=2}\times MCF_{im}\times \rho");

VEERG_4_5_1_1__6_Stage2MethaneProduction_Arguments
  =LAMBDA(
    MAKEARRAY(5, 2,
      LAMBDA(r,c,
        INDEX({
          "VSTjmT2","volatile solids transferred to treatment stage 2 MMS : kg/head/day";
          "BO","emissions potential : m3 CH4/kg VS";
          "MMSjmT2","fraction of manure in each secondary system : fraction";
          "MCFim","methane conversion factor for temperate zone and system : fraction";
          "rho","density of methane : kg/m3"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_5_1_1__7_VolatileSolidsTransferredStage2
Volatile solids transferred to treatment stage 2 MMS
VSTijmT2
kg VS
VST_{ijm,T=2}=VS_{j}\times FVS_{jm,T=1}\times(1-VSL_{m,T=1})
VSj = volatile solid production from swine in each class : kg/head/day
FVSjmT1 = fraction of volatile solids in each primary system : fraction
VSLmT1 = fraction of volatile solids lost during storage in the primary system : fraction
--------------------------------------
