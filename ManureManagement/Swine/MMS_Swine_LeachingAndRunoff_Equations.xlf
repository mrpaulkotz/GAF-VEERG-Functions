/*
============================================================================
4.5: Swine
============================================================================
4.5.1.7 Method 1 - Manure Leaching And Runoff N2O Swine
============================================================================
*/

/*
--------------------------------------
VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS
Annual emissions from leaching and runoff from each MMS
E_N2Oleach
t N2O
E_{N2O,leach}=MNLeach_{jm=5}\times EF_{leach}\times C_{N2O}\times 10^{-3}
MNLeach_jm5 = mass of N lost through leaching and runoff from drylot MMS (kg N)
EF_leach = emission factor for leaching and runoff (kg N2O-N/kg N)
C_N2O = factor to convert elemental mass of N2O to molecular mass
VARIATION OF SOURCE: Due to strict environmental controls, emissions are estimated only for drylot MMS (m=5).
--------------------------------------
*/

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS
  =LAMBDA(
    MNLeach_jm5, EF_leach, C_N2O,
    MNLeach_jm5 * EF_leach * C_N2O * 10 ^ -3
  );

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Title
  =LAMBDA("Annual emissions from leaching and runoff from each MMS");

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Variable
  =LAMBDA("E_N2Oleach");

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Unit
  =LAMBDA("t N2O");

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Source
  =LAMBDA("VEERG 2026: 4.5.1.7, Equation (1)");

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_NIRReference
  =LAMBDA("");

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_LatexEquation
  =LAMBDA("E_{N2O,leach}=MNLeach_{jm=5}\times EF_{leach}\times C_{N2O}\times 10^{-3}");

VEERG_4_5_1_7__1_AnnualEmissionsFromLeachingAndRunoffFromMMS_Arguments
  =LAMBDA(
    MAKEARRAY(3, 4,
      LAMBDA(r,c,
        INDEX({
          "MNLeach_jm5", "mass of N lost through leaching and runoff from drylot MMS", "kg N", "Calculated from 4.5.1.7 (2)";
          "EF_leach", "emission factor for leaching and runoff", "kg N2O-N/kg N", "Constant";
          "C_N2O", "factor to convert elemental mass of N2O to molecular mass", "", "Constant"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS
Mass of nitrogen lost to leaching and runoff from drylot MMS
MNLeach_jm5
kg N
MNLeach_{jm=5}=MN_{jm=5,T=1}\times FracWET\times FracLEACH_{MS}
MN_jm5T1 = nitrogen in treatment stage 1 drylot MMS (kg N)
FracWET = fraction of N available for leaching and runoff
FracLEACH_MS = fraction of N lost through leaching and runoff
--------------------------------------
*/

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS
  =LAMBDA(
    MN_jm5T1, FracWET, FracLEACH_MS,
    MN_jm5T1 * FracWET * FracLEACH_MS
  );

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS_Title
  =LAMBDA("Mass of nitrogen lost to leaching and runoff from drylot MMS");

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS_Variable
  =LAMBDA("MNLeach_jm5");

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS_Unit
  =LAMBDA("kg N");

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS_Source
  =LAMBDA("VEERG 2026: 4.5.1.7, Equation (2)");

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS_NIRReference
  =LAMBDA("");

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS_LatexEquation
  =LAMBDA("MNLeach_{jm=5}=MN_{jm=5,T=1}\times FracWET\times FracLEACH_{MS}");

VEERG_4_5_1_7__2_MassOfNitrogenLostToLeachingAndRunoffFromDrylotMMS_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "MN_jm5T1", "nitrogen in treatment stage 1 drylot MMS", "kg N", "Calculated from 4.5.1.3 (2)";
          "FracWET", "fraction of N available for leaching and runoff", "fraction", "Constant";
          "FracLEACH_MS", "fraction of N lost through leaching and runoff", "fraction", "Constant";
          "z", "location in leaching zone", "", "Input";
          "j", "production system", "", "Input";
          "ir", "irrigation method", "", "Input"
        }, r, c)
      )
    )
  );



