        INDEX({
          "VS_j","volatile solid production from feedlot cattle in each group j : kg/head/day";
          "BO","emissions potential : m3 CH4/kg VS";
          "MMS_m1T3","fraction of manure to tertiary anaerobic lagoon system : fraction";
          "MCF_im1","methane conversion factor for temperature zone and anaerobic lagoon system : fraction";
          "rho","density of methane : kg/m3";
          "i", "state"
