/*
--------------------------------------
VEERG_4_1_1_3__7_NitrogenTransferredToStage2
Nitrogen transferred to treatment stage 2 MMS
NT_jmT2
kg N
NT_{jm,T=2}=(MN_{jm=5,T=1}\times(1-FracGASM_{m=5}-EF_{m=5}))-MN_{jm,T=3}
MN_jm5T1 = nitrogen in MMS treatment stage 1 : kg N
FracGASM_m5 = fraction of N volatilised from drylot MMS : fraction
EF_m5 = nitrous oxide emission factor for drylot MMS : kg N2O-N/kg N deposited
MN_jmT3 = nitrogen in MMS treatment stage 3 : kg N
--------------------------------------
*/

VEERG_4_1_1_3__7_NitrogenTransferredToStage2
  =LAMBDA(
    MN_jm5T1, FracGASM_m5, EF_m5, MN_jmT3,
    (MN_jm5T1 * (1 - FracGASM_m5 - EF_m5)) - MN_jmT3
  );

VEERG_4_1_1_3__7_NitrogenTransferredToStage2_Title
  =LAMBDA("Nitrogen transferred to treatment stage 2 MMS");

VEERG_4_1_1_3__7_NitrogenTransferredToStage2_Variable
  =LAMBDA("NT_jmT2");

VEERG_4_1_1_3__7_NitrogenTransferredToStage2_Unit
  =LAMBDA("kg N");

VEERG_4_1_1_3__7_NitrogenTransferredToStage2_Source
  =LAMBDA("VEERG 2026: 4.1.1.3, Equation (7)");

VEERG_4_1_1_3__7_NitrogenTransferredToStage2_NIRReference
  =LAMBDA("");

VEERG_4_1_1_3__7_NitrogenTransferredToStage2_LatexEquation
  =LAMBDA("NT_{jm,T=2}=(MN_{jm=5,T=1}\times(1-FracGASM_{m=5}-EF_{m=5}))-MN_{jm,T=3}");

VEERG_4_1_1_3__7_NitrogenTransferredToStage2_Arguments
  =LAMBDA(
    MAKEARRAY(4, 2,
      LAMBDA(r,c,
        INDEX({
          "MN_jm5T1","nitrogen in MMS treatment stage 1 : kg N";
          "FracGASM_m5","fraction of N volatilised from drylot MMS : fraction";
          "EF_m5","nitrous oxide emission factor for drylot MMS : kg N2O-N/kg N deposited";
          "MN_jmT3","nitrogen in MMS treatment stage 3 : kg N"
        }, r, c)
      )
    )
  );

