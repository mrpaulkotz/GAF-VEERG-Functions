VEERG_4_1_1_1__4_Stage3MethaneProductionAnaerobicLagoon_Source
  =LAMBDA("VEERG 2026: 4.1.1.1, Equation (4)");

VEERG_4_1_1_1__4_Stage3MethaneProductionAnaerobicLagoon_NIRReference
  =LAMBDA("");

VEERG_4_1_1_1__4_Stage3MethaneProductionAnaerobicLagoon_LatexEquation
  =LAMBDA("M_{jm=1,T=3}=VS_{j}\times BO\times MMS_{m=1,T=3}\times MCF_{im=1}\times \rho");

VEERG_4_1_1_1__4_Stage3MethaneProductionAnaerobicLagoon_Arguments
  =LAMBDA(
