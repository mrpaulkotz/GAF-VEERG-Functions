/*
--------------------------------------
VEERG_4_1_1_1__5_VolatileSolidProduction
Volatile solid production
VSj
kg/head/day
VS_{j}=I_{j}\times(1-DMD_{j})\times(1-A)
Ij = dry matter intake for each group : kg DM/head/day
DMDj = dry matter digestibility for each group : fraction
A = ash content of manure : fraction
--------------------------------------
*/

VEERG_4_1_1_1__5_VolatileSolidProduction
  =LAMBDA(
    Ij, DMDj, A,
    Ij * (1 - DMDj) * (1 - A)
  );

VEERG_4_1_1_1__5_VolatileSolidProduction_Title
  =LAMBDA("Volatile solid production");

VEERG_4_1_1_1__5_VolatileSolidProduction_Variable
  =LAMBDA("VSj");

VEERG_4_1_1_1__5_VolatileSolidProduction_Unit
  =LAMBDA("kg/head/day");

VEERG_4_1_1_1__5_VolatileSolidProduction_Source
  =LAMBDA("VEERG 2026: 4.1.1.1, Equation (5)");

VEERG_4_1_1_1__5_VolatileSolidProduction_NIRReference
  =LAMBDA("");

VEERG_4_1_1_1__5_VolatileSolidProduction_LatexEquation
  =LAMBDA("VS_{j}=I_{j}\times(1-DMD_{j})\times(1-A)");

VEERG_4_1_1_1__5_VolatileSolidProduction_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "Ij","dry matter intake for each group : kg DM/head/day";
          "DMDj","dry matter digestibility for each group : fraction";
          "A","ash content of manure : fraction"
        }, r, c)
      )
    )
  );







