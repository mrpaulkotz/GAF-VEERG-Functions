/*
============================================================================
4.1: Beef Feedlot
============================================================================
4.1.1.1 Method 1 - Manure Methane Beef Feedlot
============================================================================
*/

/*
--------------------------------------
VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions
Total annual methane emissions from manure management
ECH4
t CH4
{E}_{CH4}=\sum_{j}\sum_{m}\sum_{T}(D_{j}\times M_{jmT}\times N_{j})\times10^{-3}
Dj = length of stay of each cattle group : days
MjmT = methane production from manure per cattle group, MMS, and treatment stage : kg CH4/head/day
Nj = numbers of beef cattle in each group : head
--------------------------------------
*/

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions
  =LAMBDA(
    Dj, MjmT, Nj,
    SUMPRODUCT(Dj, MjmT, Nj) * 10 ^ -3
  );

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions_Title
  =LAMBDA("Total annual methane emissions from manure management");

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions_Variable
  =LAMBDA("ECH4");

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions_Unit
  =LAMBDA("t CH4");

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions_Source
  =LAMBDA("VEERG 2026: 4.1.1.1, Equation (1)");

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions_NIRReference
  =LAMBDA("");

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions_LatexEquation
  =LAMBDA("{E}_{CH4}=\sum_{j}\sum_{m}\sum_{T}(D_{j}\times M_{jmT}\times N_{j})\times10^{-3}");

VEERG_4_1_1_1__1_TotalAnnualMethaneEmissions_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "Dj","length of stay of each cattle group : days";
          "MjmT","methane production from manure per cattle group, MMS, and treatment stage : kg CH4/head/day";
          "Nj","numbers of beef cattle in each group : head"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot
Production of methane in treatment stage 1 MMS
Mjm5T1
kg CH4/head/day
M_{jm=5,T=1}=VS_{j}\times BO\times MMS_{m=5,T=1}\times MCF_{im=5}\times \rho
VSj = volatile solid production from feedlot cattle in each group : kg/head/day
BO = emissions potential : m3 CH4/kg VS
MMSm5T1 = fraction of manure in primary system drylot MMS : fraction
MCFim5 = methane conversion factor for temperature zone and drylot system : fraction
rho = density of methane : kg/m3
--------------------------------------
*/

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot
  =LAMBDA(
    VSj, BO, MMSm5T1, MCFim5, rho,
    LET(
      MCFim5, IF(ISNUMBER(MCFim5), MCFim5, 0),
      VSj * BO * MMSm5T1 * MCFim5 * rho
    )
  );

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot_Title
  =LAMBDA("Production of methane in treatment stage 1 MMS");

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot_Variable
  =LAMBDA("Mjm5T1");

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot_Unit
  =LAMBDA("kg CH4/head/day");

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot_Source
  =LAMBDA("VEERG 2026: 4.1.1.1, Equation (2)");

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot_NIRReference
  =LAMBDA("");

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot_LatexEquation
  =LAMBDA("M_{jm=5,T=1}=VS_{j}\times BO\times MMS_{m=5,T=1}\times MCF_{im=5}\times \rho");

VEERG_4_1_1_1__2_Stage1MethaneProductionDrylot_Arguments
  =LAMBDA(
    MAKEARRAY(6, 2,
      LAMBDA(r,c,
        INDEX({
          "VSj","volatile solid production from feedlot cattle in each group : kg/head/day";
          "BO","emissions potential : m3 CH4/kg VS";
          "MMSm5T1","fraction of manure in primary system drylot MMS : fraction";
          "MCFim5","methane conversion factor for temperature zone and drylot system : fraction";
          "rho","density of methane : kg/m3";
          "i", "state"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_1_1_1__3_Stage2MethaneProduction
Production of methane in treatment stage 2 MMS
MjmT2
kg CH4/head/day
M_{jmT=2}=(1-VSL)\times VS_{j}\times BO\times MMS_{mT=2}\times MCF_{im}\times \rho
VSL = fraction of volatile solids lost during storage in the primary system : fraction
VSj = volatile solid production from feedlot cattle in each group : kg/head/day
BO = emissions potential : m3 CH4/kg VS
MMSmT2 = fraction of manure in each secondary system : fraction
MCFim = methane conversion factor for temperature zone and MMS : fraction
rho = density of methane : kg/m3
--------------------------------------
*/

VEERG_4_1_1_1__3_Stage2MethaneProduction
  =LAMBDA(
    VSL, VSj, BO, MMSmT2, MCFim, rho,
    (1 - VSL) * VSj * BO * MMSmT2 * MCFim * rho
  );

VEERG_4_1_1_1__3_Stage2MethaneProduction_Title
  =LAMBDA("Production of methane in treatment stage 2 MMS");

VEERG_4_1_1_1__3_Stage2MethaneProduction_Variable
  =LAMBDA("MjmT2");

VEERG_4_1_1_1__3_Stage2MethaneProduction_Unit
  =LAMBDA("kg CH4/head/day");

VEERG_4_1_1_1__3_Stage2MethaneProduction_Source
  =LAMBDA("VEERG 2026: 4.1.1.1, Equation (3)");

VEERG_4_1_1_1__3_Stage2MethaneProduction_NIRReference
  =LAMBDA("");

VEERG_4_1_1_1__3_Stage2MethaneProduction_LatexEquation
  =LAMBDA("M_{jmT=2}=(1-VSL)\times VS_{j}\times BO\times MMS_{mT=2}\times MCF_{im}\times \rho");

VEERG_4_1_1_1__3_Stage2MethaneProduction_Arguments
  =LAMBDA(
    MAKEARRAY(7, 2,
      LAMBDA(r,c,
        INDEX({
          "VSL","fraction of volatile solids lost during storage in the primary system : fraction";
          "VSj","volatile solid production from feedlot cattle in each group : kg/head/day";
          "BO","emissions potential : m3 CH4/kg VS";
          "MMSmT2","fraction of manure in each secondary system : fraction";
          "MCFim","methane conversion factor for temperature zone and MMS : fraction";
          "rho","density of methane : kg/m3";
          "i", "state"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_1_1_1__4_Stage3MethaneProductionAnaerobicLagoon
