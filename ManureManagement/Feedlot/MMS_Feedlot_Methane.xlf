        INDEX({
          "VSj","volatile solid production from feedlot cattle in each group : kg/head/day";
          "BO","emissions potential : m3 CH4/kg VS";
          "MMSm1T3","fraction of manure to tertiary anaerobic lagoon system : fraction";
          "MCFim1","methane conversion factor for temperature zone and anaerobic lagoon system : fraction";
          "rho","density of methane : kg/m3";
          "i", "state"
