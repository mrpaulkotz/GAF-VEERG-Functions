/*
============================================================================
4.7: Manure Management - Other Livestock
============================================================================
4.7.1.1 Method 1 - Manure Methane Other Livestock
============================================================================
*/

/*
--------------------------------------
VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock
Total annual methane production from manure management of other livestock
E_CH4
t CH4
E_{CH4}=\sum_j\sum_m(N_j\times M_jm\times 365)\times 10^{-3}
N_j = average annual number of livestock per livestock type j (head)
M_jm = annual methane production from manure management (kg CH4/head/day)
--------------------------------------
*/

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock
  =LAMBDA(
    N_j, M_jm,
    SUM(N_j * M_jm * 365) * 10 ^ -3
  );

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock_Title
  =LAMBDA("Total annual methane production from manure management of other livestock");

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock_Variable
  =LAMBDA("E_CH4");

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock_Unit
  =LAMBDA("t CH4");

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock_Source
  =LAMBDA("VEERG 2026: 4.7.1.1, Equation (1)");

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock_NIRReference
  =LAMBDA("");

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock_LatexEquation
  =LAMBDA("E_{CH4}=\sum\nolimits_j\sum\nolimits_m(N_j\times M_jm\times 365)\times 10^{-3}");

VEERG_4_7_1_1__1_TotalAnnualMethaneProductionFromManureManagementOtherLivestock_Arguments
  =LAMBDA(
    MAKEARRAY(4, 4,
      LAMBDA(r,c,
        INDEX({
          "N_j", "average annual number of livestock per livestock type j", "head", "Input";
          "M_jm", "annual methane production from manure management", "kg CH4/head/day", "Calculated from 4.7.1.1, (2)";
          "j", "livestock type", "", "Input";
          "m", "manure management system", "", "Input"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement
Annual methane production from manure management
M_jm
kg CH4/head/day
M_jm=VS_j\times B_O\times MMS_m\times MCF_im\times \rho
VS_j = volatile solid production (kg/head/day)
B_O = methane emissions potential (m3 CH4/kg VS)
MMS_m = fraction of waste in each manure management system
MCF_im = methane conversion factor for temperature zone and manure management system
rho = density of methane (kg/m3)
--------------------------------------
*/

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement
  =LAMBDA(
    VS_j, B_O, MMS_m, MCF_im, rho,
    VS_j * B_O * MMS_m * MCF_im * rho
  );

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_Title
  =LAMBDA("Annual methane production from manure management");

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_Variable
  =LAMBDA("M_jm");

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_Unit
  =LAMBDA("kg CH4/head/day");

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_Source
  =LAMBDA("VEERG 2026: 4.7.1.1, Equation (2)");

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_NIRReference
  =LAMBDA("");

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_LatexEquation
  =LAMBDA("M_{jm}=VS_j\times B_O\times MMS_m\times MCF_{im}\times \rho");

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "VS_j", "volatile solid production", "kg/head/day", "Constant";
          "B_O", "methane emissions potential", "m3 CH4/kg VS", "Constant";
          "MMS_m", "fraction of waste in each manure management system", "fraction", "Constant";
          "MCF_im", "methane conversion factor for state and manure management system", "fraction", "Constant";
          "rho", "density of methane", "kg/m3", "Constant";
          "i", "state", "", "Input"
        }, r, c)
      )
    )
  );

VEERG_4_7_1_1__2_AnnualMethaneProductionFromManureManagement_Arguments_Method2
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "VS_j", "volatile solid production", "kg/head/day", "Constant";
          "B_O", "methane emissions potential", "m3 CH4/kg VS", "Constant";
          "MMS_m", "fraction of waste in each manure management system", "fraction", "Constant";
          "MCF_im", "methane conversion factor for temperature zone and manure management system", "fraction", "Constant";
          "rho", "density of methane", "kg/m3", "Constant";
          "i", "mean annual temperature", "degrees Celsius", "Input"
        }, r, c)
      )
    )
  );
