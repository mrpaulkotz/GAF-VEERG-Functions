/*
============================================================================
4.6: Poultry
============================================================================
4.6.1.1 Method 1 - Manure Methane Poultry
============================================================================
*/

/*
--------------------------------------
VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions
Total annual methane emissions from manure management
ECH4
t CH4
{E}_{CH4}=\sum_{j}\sum_{k}(D_{jk}\times M_{mjk}\times N_{jk})\times10^{-3}
Djk = duration of stay of each class and subclass of poultry : days
Mmjk = methane production from manure in each class and subclass : kg CH4/head/day
Njk = numbers of poultry in each class and subclass : head
--------------------------------------
*/

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions
  =LAMBDA(
    Djk, Mmjk, Njk,
    SUMPRODUCT(Djk, Mmjk, Njk) * 10 ^ -3
  );

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Title
  =LAMBDA("Total annual methane emissions from manure management");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Variable
  =LAMBDA("ECH4");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Unit
  =LAMBDA("t CH4");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Source
  =LAMBDA("VEERG 2026: 4.6.1.1, Equation (1)");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_LatexEquation
  =LAMBDA("{E}_{CH4}=\sum_{j}\sum_{k}(D_{jk}\times M_{mjk}\times N_{jk})\times10^{-3}");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "Djk","duration of stay of each class and subclass of poultry : days";
          "Mmjk","methane production from manure in each class and subclass : kg CH4/head/day";
          "Njk","numbers of poultry in each class and subclass : head"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass
Methane production from the manure of poultry
Mmjk
kg CH4/head/day
M_{mjk}=\sum_{m}\sum_{T}M_{jkmT}
MjkmT = methane production from manure per class, subclass, MMS, and treatment stage : kg CH4/head/day
--------------------------------------
*/

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass
  =LAMBDA(
    MjkmT,
    SUM(MjkmT)
  );

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass_Title
  =LAMBDA("Methane production from the manure of poultry");

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass_Variable
  =LAMBDA("Mmjk");

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass_Unit
  =LAMBDA("kg CH4/head/day");

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass_Source
  =LAMBDA("VEERG 2026: 4.6.1.1, Equation (2)");

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass_LatexEquation
  =LAMBDA("M_{mjk}=\sum_{m}\sum_{T}M_{jkmT}");

VEERG_4_6_1_1__2_MethaneProductionPerClassAndSubclass_Arguments
  =LAMBDA(
    MAKEARRAY(1, 2,
      LAMBDA(r,c,
        INDEX({
          "MjkmT","methane production from manure per class, subclass, MMS, and treatment stage : kg CH4/head/day"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__3_Stage1MethaneProduction
Production of methane in treatment stage 1 MMS
MjkmT1
kg CH4/head/day
M_{jkm,T=1}=VS_{jk}\times BO_{j}\times MMS_{jm,T=1}\times MCF_{im}\times \rho
VSjk = volatile solid production for poultry classes and subclasses : kg/head/day
BOj = emissions potential per class : m3 CH4/kg VS
MMSjmT1 = fraction of manure in each primary system : fraction
MCFim = methane conversion factor for temperature zone and MMS : fraction
rho = density of methane : kg/m3
--------------------------------------
*/

VEERG_4_6_1_1__3_Stage1MethaneProduction
  =LAMBDA(
    VSjk, BOj, MMSjmT1, MCFim, rho,
    VSjk * BOj * MMSjmT1 * MCFim * rho
  );

VEERG_4_6_1_1__3_Stage1MethaneProduction_Title
  =LAMBDA("Production of methane in treatment stage 1 MMS");

VEERG_4_6_1_1__3_Stage1MethaneProduction_Variable
  =LAMBDA("MjkmT1");

VEERG_4_6_1_1__3_Stage1MethaneProduction_Unit
  =LAMBDA("kg CH4/head/day");

VEERG_4_6_1_1__3_Stage1MethaneProduction_Source
  =LAMBDA("VEERG 2026: 4.6.1.1, Equation (3)");

VEERG_4_6_1_1__3_Stage1MethaneProduction_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__3_Stage1MethaneProduction_LatexEquation
  =LAMBDA("M_{jkm,T=1}=VS_{jk}\times BO_{j}\times MMS_{jm,T=1}\times MCF_{im}\times \rho");

VEERG_4_6_1_1__3_Stage1MethaneProduction_Arguments
  =LAMBDA(
    MAKEARRAY(6, 2,
      LAMBDA(r,c,
        INDEX({
          "VSjk","volatile solid production for poultry classes and subclasses : kg/head/day";
          "BOj","emissions potential per class : m3 CH4/kg VS";
          "MMSjmT1","fraction of manure in each primary system : fraction";
          "MCFim","methane conversion factor for temperature zone and MMS : fraction";
          "rho","density of methane : kg/m3";
          "i", "state"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__4_Stage2MethaneProduction
Production of methane in treatment stage 2 MMS
MjkmT2
kg CH4/head/day
M_{jkm,T=2}=VST_{jkm,T=2}\times BO\times MMS_{jm,T=2}\times MCF_{im}\times \rho
VSTjkmT2 = volatile solids transferred to treatment stage 2 MMS : kg VS
BO = emissions potential : m3 CH4/kg VS
MMSjmT2 = fraction of manure in each secondary system : fraction
MCFim = methane conversion factor for temperature zone and MMS : fraction
rho = density of methane : kg/m3
--------------------------------------
*/

VEERG_4_6_1_1__4_Stage2MethaneProduction
  =LAMBDA(
    VSTjkmT2, BO, MMSjmT2, MCFim, rho,
    LET(
      MMSjmT2, IF(ISNUMBER((MMSjmT2)), MMSjmT2, 0),
      VSTjkmT2 * BO * MMSjmT2 * MCFim * rho
    )
  );

VEERG_4_6_1_1__4_Stage2MethaneProduction_Title
  =LAMBDA("Production of methane in treatment stage 2 MMS");

VEERG_4_6_1_1__4_Stage2MethaneProduction_Variable
  =LAMBDA("MjkmT2");

VEERG_4_6_1_1__4_Stage2MethaneProduction_Unit
  =LAMBDA("kg CH4/head/day");

VEERG_4_6_1_1__4_Stage2MethaneProduction_Source
  =LAMBDA("VEERG 2026: 4.6.1.1, Equation (4)");

VEERG_4_6_1_1__4_Stage2MethaneProduction_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__4_Stage2MethaneProduction_LatexEquation
  =LAMBDA("M_{jkm,T=2}=VST_{jkm,T=2}\times BO\times MMS_{jm,T=2}\times MCF_{im}\times \rho");

VEERG_4_6_1_1__4_Stage2MethaneProduction_Arguments
  =LAMBDA(
    MAKEARRAY(6, 2,
      LAMBDA(r,c,
        INDEX({
          "VSTjkmT2","volatile solids transferred to treatment stage 2 MMS : kg VS";
          "BO","emissions potential : m3 CH4/kg VS";
          "MMSjmT2","fraction of manure in each secondary system : fraction";
          "MCFim","methane conversion factor for temperature zone and MMS : fraction";
          "rho","density of methane : kg/m3";
          "i", "state"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2
Volatile solids transferred to treatment stage 2 MMS
VSTjkmT2
kg VS
VST_{jkm,T=2}=VS_{jk}\times MMS_{jm,T=1}\times(1-VSL_{m,T=1})
VSjk = volatile solid production for poultry classes and subclasses : kg/head/day
MMSjmT1 = fraction of manure in each primary system : fraction
VSLmT1 = fraction of volatile solids lost during storage in the primary system : fraction
--------------------------------------
*/

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2
  =LAMBDA(
    VSjk, MMSjmT1, VSLmT1,
    LET(
      VSLmT1, IF(ISNUMBER((VSLmT1)), VSLmT1, 0),
      VSjk * MMSjmT1 * (1 - VSLmT1)
    )
  );

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2_Title
  =LAMBDA("Volatile solids transferred to treatment stage 2 MMS");

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2_Variable
  =LAMBDA("VSTjkmT2");

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2_Unit
  =LAMBDA("kg VS");

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2_Source
  =LAMBDA("VEERG 2026: 4.6.1.1, Equation (5)");

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2_LatexEquation
  =LAMBDA("VST_{jkm,T=2}=VS_{jk}\times MMS_{jm,T=1}\times(1-VSL_{m,T=1})");

VEERG_4_6_1_1__5_VolatileSolidsTransferredToStage2_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "VSjk","volatile solid production for poultry classes and subclasses : kg/head/day";
          "MMSjmT1","fraction of manure in each primary system : fraction";
          "VSLmT1","fraction of volatile solids lost during storage in the primary system : fraction"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__6_VolatileSolidProduction
Volatile solid production
VSjk
kg/head/day
VS_{jk}=I_{jk}\times(1-DMD_{jk})\times(1-A_{j})
Ijk = dry matter intake for each class and subclass : kg DM/head/day
DMDjk = dry matter digestibility for each class and subclass : fraction
Aj = ash content of manure for each class and subclass : fraction
--------------------------------------
*/

VEERG_4_6_1_1__6_VolatileSolidProduction
  =LAMBDA(
    Ijk, DMDjk, Aj,
    Ijk * (1 - DMDjk) * (1 - Aj)
  );

VEERG_4_6_1_1__6_VolatileSolidProduction_Title
  =LAMBDA("Volatile solid production");

VEERG_4_6_1_1__6_VolatileSolidProduction_Variable
  =LAMBDA("VSjk");

VEERG_4_6_1_1__6_VolatileSolidProduction_Unit
  =LAMBDA("kg/head/day");

VEERG_4_6_1_1__6_VolatileSolidProduction_Source
  =LAMBDA("VEERG 2026: 4.6.1.1, Equation (6)");

VEERG_4_6_1_1__6_VolatileSolidProduction_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__6_VolatileSolidProduction_LatexEquation
  =LAMBDA("VS_{jk}=I_{jk}\times(1-DMD_{jk})\times(1-A_{j})");

VEERG_4_6_1_1__6_VolatileSolidProduction_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "Ijk","dry matter intake for each class and subclass : kg DM/head/day";
          "DMDjk","dry matter digestibility for each class and subclass : fraction";
          "Aj","ash content of manure for each class and subclass : fraction"
        }, r, c)
      )
    )
  );


