/*
============================================================================
4.6: Poultry
============================================================================
4.6.1.5 Method 1 - Manure Atmospheric Deposition Poultry
============================================================================
*/

/*
--------------------------------------
VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS
Total annual atmospheric deposition emissions from manure management
E_N2Oad
t N2O
E_{N2O,ad}=(MMS_{ATMOS}\times EF_{N2O}\times C_{N2O})\times10^{-3}
MMS_ATMOS = mass of N volatilised from MMS : kg N
EF_N2O = nitrous oxide emission factor for atmospheric deposition : kg N2O-N/kg N
C_N2O = factor to convert elemental mass of nitrous oxide to molecular mass : ratio
--------------------------------------
*/

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS
  =LAMBDA(
    MMS_ATMOS, EF_N2O, C_N2O,
    (MMS_ATMOS * EF_N2O * C_N2O) * 10 ^ -3
  );

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS_Title
  =LAMBDA("Total annual atmospheric deposition emissions from manure management");

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS_Variable
  =LAMBDA("E_N2Oad");

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS_Unit
  =LAMBDA("t N2O");

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS_Source
  =LAMBDA("VEERG 2026: 4.6.1.5, Equation (1)");

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS_NIRReference
  =LAMBDA("");

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS_LatexEquation
  =LAMBDA("E_{N2O,ad}=(MMS_{ATMOS}\times EF_{N2O}\times C_{N2O})\times10^{-3}");

VEERG_4_6_1_5__1_TotalAnnualAtmosphericDepositionEmissionsFromMMS_Arguments
  =LAMBDA(
    MAKEARRAY(6, 2,
      LAMBDA(r,c,
        INDEX({
          "MMS_ATMOS","mass of N volatilised from MMS : kg N";
          "EF_N2O","nitrous oxide emission factor for atmospheric deposition : kg N2O-N/kg N";
          "C_N2O","factor to convert elemental mass of nitrous oxide to molecular mass : ratio";
          "j", "production system";
          "ir", "irrigation method";
          "r", "rainfall region"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS
Total nitrogen volatilised from manure management systems
MMS_ATMOS
kg N
MMS_{ATMOS}=\sum_{j}\sum_{k}\sum_{m}\sum_{T}(MN_{jkmT}\times FracGASM_{mT})
MN_jkmT = nitrogen in each treatment stage MMS (excluding MN_jkm13T2) : kg N
FracGASM_mT = fraction of N volatilised in each MMS : (kg NH3-N + NOx-N)/kg N
--------------------------------------
*/

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS
  =LAMBDA(
    MN_jkmT, FracGASM_mT,
    MN_jkmT * FracGASM_mT
  );

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS_Title
  =LAMBDA("Total nitrogen volatilised from manure management systems");

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS_Variable
  =LAMBDA("MMS_ATMOS");

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS_Unit
  =LAMBDA("kg N");

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS_Source
  =LAMBDA("VEERG 2026: 4.6.1.5, Equation (2)");

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS_NIRReference
  =LAMBDA("");

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS_LatexEquation
  =LAMBDA("MMS_{ATMOS}=\sum_{j}\sum_{k}\sum_{m}\sum_{T}(MN_{jkmT}\times FracGASM_{mT})");

VEERG_4_6_1_5__2_TotalNitrogenVolatilisedFromMMS_Arguments
  =LAMBDA(
    MAKEARRAY(2, 2,
      LAMBDA(r,c,
        INDEX({
          "MN_jkmT","nitrogen in each treatment stage MMS (excluding MN_jkm13T2) : kg N";
          "FracGASM_mT","fraction of N volatilised in each MMS : (kg NH3-N + NOx-N)/kg N"
        }, r, c)
      )
    )
  );
