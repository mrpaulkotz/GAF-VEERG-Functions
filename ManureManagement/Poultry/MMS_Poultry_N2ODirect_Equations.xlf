/*
============================================================================
4.6: Poultry
============================================================================
4.6.1.3 Method 1 - Manure Direct N2O Poultry
============================================================================
*/

/*
--------------------------------------
VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS
Total annual direct nitrous oxide emissions from manure management systems
E_N2Odir
t N2O
E_{N2O,dir}=\sum_{j}\sum_{k}\sum_{m}\sum_{T}(MN_{jkmT}\times EF_{jm}\times C_{N2O})\times10^{-3}
MN_jkmT = nitrogen per poultry class, subclass, MMS and treatment stage : kg N
EF_jm = nitrous oxide emission factor for MMS : kg N2O-N/kg N
C_N2O = factor to convert elemental mass of nitrous oxide to molecular mass : ratio
--------------------------------------
*/

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS
  =LAMBDA(
    MN_jkmT, EF_jm, C_N2O,
    MN_jkmT * EF_jm * C_N2O * 10 ^ -3
  );

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Title
  =LAMBDA("Total annual direct nitrous oxide emissions from manure management systems");

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Variable
  =LAMBDA("E_N2Odir");

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Unit
  =LAMBDA("t N2O");

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Source
  =LAMBDA("VEERG 2026: 4.6.1.3, Equation (1)");

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_NIRReference
  =LAMBDA("");

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_LatexEquation
  =LAMBDA("E_{N2O,dir}=\sum_{j}\sum_{k}\sum_{m}\sum_{T}(MN_{jkmT}\times EF_{jm}\times C_{N2O})\times10^{-3}");

VEERG_4_6_1_3__1_TotalAnnualDirectNitrousOxideEmissionsFromMMS_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "MN_jkmT","nitrogen per poultry class, subclass, MMS and treatment stage : kg N";
          "EF_jm","nitrous oxide emission factor for MMS : kg N2O-N/kg N";
          "C_N2O","factor to convert elemental mass of nitrous oxide to molecular mass : ratio"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_3__2_Stage1NitrogenInMMS
Nitrogen in treatment stage 1 MMS
MN_jkmT1
kg N
MN_{jkm,T=1}=AE_{jk}\times MMS_{jm,T=1}
AE_jk = total nitrogen excreted by each poultry class and subclass : kg N
MMS_jmT1 = fraction of manure in each primary system : fraction
--------------------------------------
*/

VEERG_4_6_1_3__2_Stage1NitrogenInMMS
  =LAMBDA(
    AE_jk, MMS_jmT1,
    AE_jk * MMS_jmT1
  );

VEERG_4_6_1_3__2_Stage1NitrogenInMMS_Title
  =LAMBDA("Nitrogen in treatment stage 1 MMS");

VEERG_4_6_1_3__2_Stage1NitrogenInMMS_Variable
  =LAMBDA("MN_jkmT1");

VEERG_4_6_1_3__2_Stage1NitrogenInMMS_Unit
  =LAMBDA("kg N");

VEERG_4_6_1_3__2_Stage1NitrogenInMMS_Source
  =LAMBDA("VEERG 2026: 4.6.1.3, Equation (2)");

VEERG_4_6_1_3__2_Stage1NitrogenInMMS_NIRReference
  =LAMBDA("");

VEERG_4_6_1_3__2_Stage1NitrogenInMMS_LatexEquation
  =LAMBDA("MN_{jkm,T=1}=AE_{jk}\times MMS_{jm,T=1}");

VEERG_4_6_1_3__2_Stage1NitrogenInMMS_Arguments
  =LAMBDA(
    MAKEARRAY(2, 2,
      LAMBDA(r,c,
        INDEX({
          "AE_jk","total nitrogen excreted by each poultry class and subclass : kg N";
          "MMS_jmT1","fraction of manure in each primary system : fraction"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_3__3_AnnualNitrogenExcretion
Annual nitrogen excretion for each poultry class and subclass
AE_jk
kg N
AE_{jk}=N_{jk}\times NE_{jk}\times D_{jk}
N_jk = number of poultry in each class and subclass : bird
NE_jk = nitrogen excretion : kg N/bird/day
D_jk = duration of stay of each class and subclass : days
--------------------------------------
*/

VEERG_4_6_1_3__3_AnnualNitrogenExcretion
  =LAMBDA(
    N_jk, NE_jk, D_jk,
    N_jk * NE_jk * D_jk
  );

VEERG_4_6_1_3__3_AnnualNitrogenExcretion_Title
  =LAMBDA("Annual nitrogen excretion for each poultry class and subclass");

VEERG_4_6_1_3__3_AnnualNitrogenExcretion_Variable
  =LAMBDA("AE_jk");

VEERG_4_6_1_3__3_AnnualNitrogenExcretion_Unit
  =LAMBDA("kg N");

VEERG_4_6_1_3__3_AnnualNitrogenExcretion_Source
  =LAMBDA("VEERG 2026: 4.6.1.3, Equation (3)");

VEERG_4_6_1_3__3_AnnualNitrogenExcretion_NIRReference
  =LAMBDA("");

VEERG_4_6_1_3__3_AnnualNitrogenExcretion_LatexEquation
  =LAMBDA("AE_{jk}=N_{jk}\times NE_{jk}\times D_{jk}");

VEERG_4_6_1_3__3_AnnualNitrogenExcretion_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "N_jk","number of poultry in each class and subclass : bird";
          "NE_jk","nitrogen excretion : kg N/bird/day";
          "D_jk","duration of stay of each class and subclass : days"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_3__4_NitrogenExcretionPerBird
Nitrogen excretion per bird per day
NE_jk
kg N/bird/day
NE_{jk}=NI_{jk}\times(1-NR_{jk})
NI_jk = nitrogen intake : kg N/bird/day
NR_jk = nitrogen retention expressed as a fraction of intake : fraction
--------------------------------------
*/

VEERG_4_6_1_3__4_NitrogenExcretionPerBird
  =LAMBDA(
    NI_jk, NR_jk,
    NI_jk * (1 - NR_jk)
  );

VEERG_4_6_1_3__4_NitrogenExcretionPerBird_Title
  =LAMBDA("Nitrogen excretion per bird per day");

VEERG_4_6_1_3__4_NitrogenExcretionPerBird_Variable
  =LAMBDA("NE_jk");

VEERG_4_6_1_3__4_NitrogenExcretionPerBird_Unit
  =LAMBDA("kg N/bird/day");

VEERG_4_6_1_3__4_NitrogenExcretionPerBird_Source
  =LAMBDA("VEERG 2026: 4.6.1.3, Equation (4)");

VEERG_4_6_1_3__4_NitrogenExcretionPerBird_NIRReference
  =LAMBDA("");

VEERG_4_6_1_3__4_NitrogenExcretionPerBird_LatexEquation
  =LAMBDA("NE_{jk}=NI_{jk}\times(1-NR_{jk})");

VEERG_4_6_1_3__4_NitrogenExcretionPerBird_Arguments
  =LAMBDA(
    MAKEARRAY(2, 2,
      LAMBDA(r,c,
        INDEX({
          "NI_jk","nitrogen intake : kg N/bird/day";
          "NR_jk","nitrogen retention expressed as a fraction of intake : fraction"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_3__5_NitrogenIntake
Nitrogen intake of poultry
NI_jk
kg N/bird/day
NI_{jk}=I_{jk}\times CP_{jk}\div 6.25
I_jk = dry matter intake for each class and subclass : kg DM/bird/day
CP_jk = crude protein content of feed : fraction
6.25 = factor for converting crude protein into nitrogen : ratio
--------------------------------------
*/

VEERG_4_6_1_3__5_NitrogenIntake
  =LAMBDA(
    I_jk, CP_jk,
    I_jk * CP_jk / 6.25
  );

VEERG_4_6_1_3__5_NitrogenIntake_Title
  =LAMBDA("Nitrogen intake of poultry");

VEERG_4_6_1_3__5_NitrogenIntake_Variable
  =LAMBDA("NI_jk");

VEERG_4_6_1_3__5_NitrogenIntake_Unit
  =LAMBDA("kg N/bird/day");

VEERG_4_6_1_3__5_NitrogenIntake_Source
  =LAMBDA("VEERG 2026: 4.6.1.3, Equation (5)");

VEERG_4_6_1_3__5_NitrogenIntake_NIRReference
  =LAMBDA("");

VEERG_4_6_1_3__5_NitrogenIntake_LatexEquation
  =LAMBDA("NI_{jk}=I_{jk}\times CP_{jk}\div 6.25");

VEERG_4_6_1_3__5_NitrogenIntake_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "I_jk","dry matter intake for each class and subclass : kg DM/bird/day";
          "CP_jk","crude protein content of feed : fraction";
          "6.25","factor for converting crude protein into nitrogen : ratio"
        }, r, c)
      )
    )
  );

