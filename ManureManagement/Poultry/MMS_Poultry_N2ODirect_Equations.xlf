/*
--------------------------------------
VEERG_4_6_1_3__7_NitrogenTransferredToStage2MMS
Nitrogen transferred to treatment stage 2 MMS
NT_jkmT2
kg N
NT_{jkm,T=2}=MN_{jkm,T=1}\times(1-FracGASM_{m,T=1}-EF_{m,T=1})
MN_jkmT1 = nitrogen in MMS treatment stage 1 : kg N
FracGASM_mT1 = fraction of N volatilised from MMS treatment at stage 1 : fraction
EF_mT1 = nitrous oxide emission factor for MMS treatment at stage 1 : kg N2O-N/kg N
--------------------------------------
*/

VEERG_4_6_1_3__7_NitrogenTransferredToStage2MMS
  =LAMBDA(
    MN_jkmT1, FracGASM_mT1, EF_mT1,
    MN_jkmT1 * (1 - FracGASM_mT1 - EF_mT1)
  );

