VEERG_4_6_1_3__6_Stage2NitrogenInMMS_LatexEquation
  =LAMBDA("MN_{jkm,T=2}=NT_{jkm,T=2}\times MMS_{m,T=2}");

VEERG_4_6_1_3__6_Stage2NitrogenInMMS_Arguments
