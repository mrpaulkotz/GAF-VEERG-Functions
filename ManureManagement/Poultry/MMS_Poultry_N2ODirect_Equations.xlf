VEERG_4_6_1_3__7_NitrogenTransferredToStage2MMS_Source
  =LAMBDA("VEERG 2026: 4.6.1.3, Equation (7)");

VEERG_4_6_1_3__7_NitrogenTransferredToStage2MMS_NIRReference
  =LAMBDA("");

VEERG_4_6_1_3__7_NitrogenTransferredToStage2MMS_LatexEquation
  =LAMBDA("NT_{jkm,T=2}=MN_{jkm,T=1}\times(1-FracGASM_{m,T=1}-EF_{m,T=1})");

VEERG_4_6_1_3__7_NitrogenTransferredToStage2MMS_Arguments
  =LAMBDA(
    MAKEARRAY(3, 2,
      LAMBDA(r,c,
        INDEX({
          "MN_jkmT1","nitrogen in MMS treatment stage 1 : kg N";
          "FracGASM_mT1","fraction of N volatilised from MMS treatment at stage 1 : fraction";
          "EF_mT1","nitrous oxide emission factor for MMS treatment at stage 1 : kg N2O-N/kg N"
