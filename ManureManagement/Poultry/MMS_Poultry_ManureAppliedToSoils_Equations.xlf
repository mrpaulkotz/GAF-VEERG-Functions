/*
============================================================================
4.6: Poultry
============================================================================
4.6.1.9 Manure Applied to Soils
============================================================================
*/

/*
--------------------------------------
VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1
Mass of nitrogen applied to soils for scope 1 emissions
MNSoil_scope1
kg N
MNSoil_{scope1}=\sum_{j}\sum_{m}(MN_{jm,T=2}\times(1-EF_{mT=2}-FracGASM_{mT=2})-MNLeach_{MMS})\times PF
MN_jmT2 = mass of N in secondary treatment stage as calculated for manure management : kg N
EF_mT2 = nitrous oxide emission factor for each MMS : kg N2O-N/kg N
FracGASM_mT2 = fraction of animal waste N volatilised in each MMS : (kg NH3-N + NOx-N)/kg N
MNLeach_MMS = mass of N lost through leaching and runoff from MMS : kg N
PF = fraction of manure applied to soil within the farm boundary : fraction
--------------------------------------
*/

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1
  =LAMBDA(
    MN_jmT2, EF_mT2, FracGASM_mT2, MNLeach_MMS, PF,
    (MN_jmT2 * (1 - EF_mT2 - FracGASM_mT2) - MNLeach_MMS) * PF
  );

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1_Title
  =LAMBDA("Mass of nitrogen applied to soils for scope 1 emissions");

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1_Variable
  =LAMBDA("MNSoil_scope1");

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1_Unit
  =LAMBDA("kg N");

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1_Source
  =LAMBDA("VEERG 2026: 4.6.1.9, Equation (1)");

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1_NIRReference
  =LAMBDA("");

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1_LatexEquation
  =LAMBDA("MNSoil_{scope1}=\sum_{j}\sum_{m}(MN_{jm,T=2}\times(1-EF_{mT=2}-FracGASM_{mT=2})-MNLeach_{MMS})\times PF");

VEERG_4_6_1_9__1_MassOfNitrogenAppliedToSoilsScope1_Arguments
  =LAMBDA(
    MAKEARRAY(5, 4,
      LAMBDA(r,c,
        INDEX({
          "MN_jmT2","mass of N in secondary treatment stage as calculated for manure management", "kg N", "Calculated from 4.6.1.3 (6)";
          "EF_mT2","nitrous oxide emission factor for each MMS", "kg N2O-N/kg N", "Constant";
          "FracGASM_mT2","fraction of animal waste N volatilised in each MMS", "(kg NH3-N + NOx-N)/kg N", "Constant";
          "MNLeach_MMS","mass of N lost through leaching and runoff from MMS", "kg N", "Calculated from 4.6.1.7 (2)";
          "PF","fraction of manure applied to soil within the farm boundary", "fraction", "Input"
        }, r, c)
      )
    )
  );

