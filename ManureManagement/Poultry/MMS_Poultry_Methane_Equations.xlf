/*
============================================================================
4.6: Poultry
============================================================================
4.6.1.1 Method 1 - Manure Methane Poultry
============================================================================
*/

/*
--------------------------------------
VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions
Total annual methane emissions from manure management
E_CH4
t CH4
E_{CH4}=\sum_{j}\sum_{k}\sum_{m}\sum_{T}(D_{jk}\times M_{jkmT}\times N_{jk})\times10^{-3}
D_jk = duration of stay of each class and subclass of poultry : days
M_jkmT = methane production from manure per class, subclass, MMS, and treatment stage : kg CH4/bird/day
N_jk = numbers of poultry in each class and subclass : bird
--------------------------------------
*/

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions
  =LAMBDA(
    D_jk, M_jkmT, N_jk,
    (D_jk * M_jkmT * N_jk) * 10 ^ -3
  );

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Title
  =LAMBDA("Total annual methane emissions from manure management");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Variable
  =LAMBDA("E_CH4");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Unit
  =LAMBDA("t CH4");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Source
  =LAMBDA("VEERG 2026: 4.4.1.1, Equation (1)");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_LatexEquation
  =LAMBDA("E_{CH4}=\sum_{j}\sum_{k}\sum_{m}\sum_{T}(D_{jk}\times M_{jkmT}\times N_{jk})\times10^{-3}");

VEERG_4_6_1_1__1_TotalAnnualMethaneEmissions_Arguments
  =LAMBDA(
    MAKEARRAY(3, 4,
      LAMBDA(r,c,
        INDEX({
          "D_jk","duration of stay of each class and subclass of poultry", "days", "Input";
          "M_jkmT","methane production from manure per class, subclass, MMS, and treatment stage", "kg CH4/bird/day", "Calculated from 4.6.1.1 (2)(3)";
          "N_jk","numbers of poultry in each class and subclass", "birds", "Input"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__2_Stage1MethaneProduction
Production of methane in treatment stage 1 MMS
M_jkmT1
kg CH4/bird/day
M_{jkmT=1}=VS_{jk}\times BO_{j}\times MMS_{jmT=1}\times MCF_{im}\times \rho
VS_jk = volatile solid production poultry classes : kg VS/bird/day
BO_j = emissions potential per class : m3 CH4/kg VS
MMS_jmT1 = fraction of manure in each primary system : fraction
MCF_im = methane conversion factor for temperature zone and MMS : fraction
rho = density of methane : kg/m3
--------------------------------------
*/

VEERG_4_6_1_1__2_Stage1MethaneProduction
  =LAMBDA(
    VS_jk, BO_j, MMS_jmT1, MCF_im, rho,
    VS_jk * BO_j * MMS_jmT1 * MCF_im * rho
  );

VEERG_4_6_1_1__2_Stage1MethaneProduction_Title
  =LAMBDA("Production of methane in treatment stage 1 MMS");

VEERG_4_6_1_1__2_Stage1MethaneProduction_Variable
  =LAMBDA("M_jkmT1");

VEERG_4_6_1_1__2_Stage1MethaneProduction_Unit
  =LAMBDA("kg CH4/bird/day");

VEERG_4_6_1_1__2_Stage1MethaneProduction_Source
  =LAMBDA("VEERG 2026: 4.4.1.1, Equation (2)");

VEERG_4_6_1_1__2_Stage1MethaneProduction_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__2_Stage1MethaneProduction_LatexEquation
  =LAMBDA("M_{jkmT=1}=VS_{jk}\times BO_{j}\times MMS_{jmT=1}\times MCF_{im}\times \rho");

VEERG_4_6_1_1__2_Stage1MethaneProduction_Arguments
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "VS_jk","volatile solid production poultry classes", "kg VS/bird/day", "Calculated from 4.6.1.1 (5)";
          "BO_j","emissions potential per class", "m3 CH4/kg VS", "Constant";
          "MMS_jmT1","fraction of manure in each primary system", "fraction", "Input";
          "MCF_im","methane conversion factor for temperature zone and MMS", "fraction", "Constant";
          "rho","density of methane", "kg/m3", "Constant";
          "i", "state", "", "Input"
        }, r, c)
      )
    )
  );

VEERG_4_6_1_1__2_Stage1MethaneProduction_Arguments_Method2
  =LAMBDA(
    MAKEARRAY(6, 4,
      LAMBDA(r,c,
        INDEX({
          "VS_jk","volatile solid production poultry classes", "kg VS/bird/day", "Calculated from 4.6.1.1 (5)";
          "BO_j","emissions potential per class", "m3 CH4/kg VS", "Constant";
          "MMS_jmT1","fraction of manure in each primary system", "fraction", "Input";
          "MCF_im","methane conversion factor for temperature zone and MMS", "fraction", "Constant";
          "rho","density of methane", "kg/m3", "Constant";
          "i", "mean annual temperature", "°C", "Input"
        }, r, c)
      )
    )
  );

VEERG_4_6_1_1__2_Stage1MethaneProduction_Variation
   =LAMBDA(
    MAKEARRAY(3, 1,
      LAMBDA(r,c,
        INDEX({
          "VARIATION ON SOURCE:";
          "Used mean annual temperature instead of temperature zone to determine MCF as MCF values are specific to temperature";
          "Method 2: Used state based MCF values for 'Belt manure removal' and 'Manure stored in house' MMS as no temperature values exist in Table A.1.8.1"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__3_Stage2MethaneProduction
Production of methane in treatment stage 2 MMS
M_jkmT2
kg CH4/bird/day
M_{jkmT=2}=VST_{jk}\times BO\times MMS_{jmT=2}\times MCF_{im}\times \rho
VST_jk = volatile solids transferred to treatment stage 2 MMS : kg VS/bird/day
BO = emissions potential : m3 CH4/kg VS
MMS_jmT2 = fraction of manure in each secondary system : fraction
MCF_im = methane conversion factor for temperature zone and MMS : fraction
rho = density of methane : kg/m3
--------------------------------------
*/

VEERG_4_6_1_1__3_Stage2MethaneProduction
  =LAMBDA(
    VST_jk, BO, MMS_jmT2, MCF_im, rho,
    VST_jk * BO * MMS_jmT2 * MCF_im * rho
