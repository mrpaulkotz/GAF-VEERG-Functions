/*
--------------------------------------
VEERG_4_6_1_1__4_VolatileSolidsTransferred
Volatile solids transferred to treatment stage 2 MMS
VST_jk
kg VS/bird/day
VST_{jk}=VS_{jk}\times MMS_{jmT=1}\times (1-VSL_{mT=1})
VS_jk = volatile solid production poultry classes : kg VS/bird/day
MMS_jmT1 = fraction of manure in each primary system : fraction
VSL_mT1 = fraction of volatile solids lost during storage in the primary system : fraction
--------------------------------------
*/

VEERG_4_6_1_1__4_VolatileSolidsTransferred
  =LAMBDA(
    VS_jk, MMS_jmT1, VSL_mT1,
    VS_jk * MMS_jmT1 * (1 - VSL_mT1)
  );

VEERG_4_6_1_1__4_VolatileSolidsTransferred_Title
  =LAMBDA("Volatile solids transferred to treatment stage 2 MMS");

VEERG_4_6_1_1__4_VolatileSolidsTransferred_Variable
  =LAMBDA("VST_jk");

VEERG_4_6_1_1__4_VolatileSolidsTransferred_Unit
  =LAMBDA("kg VS/bird/day");

VEERG_4_6_1_1__4_VolatileSolidsTransferred_Source
  =LAMBDA("VEERG 2026: 4.4.1.1, Equation (4)");

VEERG_4_6_1_1__4_VolatileSolidsTransferred_NIRReference
