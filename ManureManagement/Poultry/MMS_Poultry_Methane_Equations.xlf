VEERG_4_6_1_1__4_VolatileSolidsTransferred_LatexEquation
  =LAMBDA("VST_{jk}=VS_{jk}\times MMS_{jmT=1}\times (1-VSL_{mT=1})");

VEERG_4_6_1_1__4_VolatileSolidsTransferred_Arguments
  =LAMBDA(
    MAKEARRAY(3, 4,
      LAMBDA(r,c,
        INDEX({
          "VS_jk","volatile solid production poultry classes", "kg VS/bird/day", "Calculated from 4.6.1.1 (5)";
          "MMS_jmT1","fraction of manure in each primary system", "fraction", "Input";
          "VSL_mT1","fraction of volatile solids lost during storage in the primary system", "fraction", "Constant"
        }, r, c)
      )
    )
  );

/*
--------------------------------------
VEERG_4_6_1_1__5_VolatileSolidProduction
Volatile solid production poultry classes
VS_jk
kg VS/bird/day
VS_{jk}=I_{jk}\times (1-DMD_{jk})\times (1-A_{j})
I_jk = dry matter intake for each class and subclass : kg DM/bird/day
DMD_jk = dry matter digestibility for each class and subclass : fraction
A_j = ash content of manure for each class and subclass : fraction
--------------------------------------
*/

VEERG_4_6_1_1__5_VolatileSolidProduction
  =LAMBDA(
    I_jk, DMD_jk, A_j,
    I_jk * (1 - DMD_jk) * (1 - A_j)
  );

VEERG_4_6_1_1__5_VolatileSolidProduction_Title
  =LAMBDA("Volatile solid production poultry classes");

VEERG_4_6_1_1__5_VolatileSolidProduction_Variable
  =LAMBDA("VS_jk");

VEERG_4_6_1_1__5_VolatileSolidProduction_Unit
  =LAMBDA("kg VS/bird/day");

VEERG_4_6_1_1__5_VolatileSolidProduction_Source
  =LAMBDA("VEERG 2026: 4.4.1.1, Equation (5)");

VEERG_4_6_1_1__5_VolatileSolidProduction_NIRReference
  =LAMBDA("");

VEERG_4_6_1_1__5_VolatileSolidProduction_LatexEquation
  =LAMBDA("VS_{jk}=I_{jk}\times (1-DMD_{jk})\times (1-A_{j})");

VEERG_4_6_1_1__5_VolatileSolidProduction_Arguments
  =LAMBDA(
    MAKEARRAY(3, 4,
      LAMBDA(r,c,
        INDEX({
          "I_jk","dry matter intake for each class and subclass", "kg DM/bird/day", "Input";
          "DMD_jk","dry matter digestibility for each class and subclass", "fraction", "Input";
          "A_j","ash content of manure for each class and subclass", "fraction", "Constant"
