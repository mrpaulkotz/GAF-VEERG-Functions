/*
======================================
8: Fuel Use
======================================
8.1 Fuel Use - Transport fuel
======================================
*/


VEERG_8_FuelCombustion
  =LAMBDA(
    Q, EC, EF,
    (Q * EC * EF) * 10 ^ - 3
  )
;

/* 
--------------------------------------
VEERG_8_1_1_1__1_FuelCombustionTransport
Emissions for each GHG from the combustion of fuels for transport energy purposes
Q : Amount of fuel type q combusted for transport energy purposes : kL
EC : energy content factor for transport energy purposes : GJ/kL
EF : Scope 1 emission factor for transport energy purposes for each greenhouse gas : kg CO2e / GJ
--------------------------------------
*/


VEERG_8_1_1_1__1_FuelCombustionTransport
  =LAMBDA(
    Q_Transtq, EC_Transq, EF_Trans1tqg,
    VEERG_8_FuelCombustion(Q_Transtq, EC_Transq, EF_Trans1tqg)
  )
;

VEERG_8_1_1_1__1_FuelCombustionTransport_Title
  =LAMBDA("Emissions for each GHG from the combustion of fuels for transport energy purposes");

VEERG_8_1_1_1__1_FuelCombustionTransport_Variable
  =LAMBDA("E_g");

VEERG_8_1_1_1__1_FuelCombustionTransport_Unit
  =LAMBDA("t CO2-e");

VEERG_8_1_1_1__1_FuelCombustionTransport_Source
  =LAMBDA("VEERG 2026: 8.1.1.1, Equation (1)");

VEERG_8_1_1_1__1_FuelCombustionTransport_NIRReference
  =LAMBDA("Australian National Greenhouse Accounts Factors 2025 - 2.3 Estimating emissions from transport fuels");

VEERG_8_1_1_1__1_FuelCombustionTransport_LatexEquation
  =LAMBDA("E_g=\sum\nolimits_t \sum\nolimits_q\left(Q_{Trans,tq}\times EC_{Trans,q}\times EF_{Trans,1,tqg}\right)\times 10^{-3}");

VEERG_8_1_1_1__1_FuelCombustionTransport_Arguments
  =LAMBDA(
    MAKEARRAY(7, 4, 
      LAMBDA(r,c, 
        INDEX({
          "Q_Transtq", "Amount of fuel type q combusted for transport energy purposes", "Varies based on fuel type: kL, m3, GJ", "Input";
          "EC_Transq", "Energy content factor for transport energy purposes", "GJ / unit of fuel", "Constant";
          "EF_Trans1tqg", "Scope 1 emission factor for transport energy purposes for each greenhouse gas", "kg CO2e / GJ", "Constant";
          "q", "Fuel type", "", "Constant";
          "Trans", "Transport combustion", "", "Constant";
          "g", "Greenhouse gas", "", "Constant";
          "1", "Scope 1", "", "Constant"
        }, r, c)
      )
    )
  );

/* 
--------------------------------------
VEERG_8_2_1_1__1_FuelCombustionStationary
Emissions for each GHG from the stationary combustion of fuels
Q : Amount of fuel type q used for stationary combustion operations : kL
EC : Energy content factor for stationary combustion operations : GJ/kL
EF : Scope 1 emission factor for stationary combustion for each greenhouse gas : kg CO2e / GJ
--------------------------------------
*/


VEERG_8_2_1_1__1_FuelCombustionStationary
  =LAMBDA(
    Q_SCq, EC_SCq, EF_SC1qg,
    VEERG_8_FuelCombustion(Q_SCq, EC_SCq, EF_SC1qg)
  )
;

VEERG_8_2_1_1__1_FuelCombustionStationary_Title
  =LAMBDA("Emissions for each GHG from the stationary combustion of fuels");

VEERG_8_2_1_1__1_FuelCombustionStationary_Variable
  =LAMBDA("E_g");

VEERG_8_2_1_1__1_FuelCombustionStationary_Unit
  =LAMBDA("t CO2-e");

VEERG_8_2_1_1__1_FuelCombustionStationary_Source
  =LAMBDA("VEERG 2026: 8.2.1.1, Equation (1)");

VEERG_8_2_1_1__1_FuelCombustionStationary_NIRReference
  =LAMBDA("Australian National Greenhouse Accounts Factors 2025 - 2.2 Estimating emissions from stationary energy sources - Calculating emissions from stationary combustion of liquid fuels");

VEERG_8_2_1_1__1_FuelCombustionStationary_LatexEquation
  =LAMBDA("E_g=\sum\nolimits_t \sum\nolimits_q\left(Q_{SC,q}\times EC_{SC,q}\times EF_{SC,1,qg}\right)\times 10^{-3}");

VEERG_8_2_1_1__1_FuelCombustionStationary_Arguments
  =LAMBDA(
    MAKEARRAY(7, 4, 
      LAMBDA(r,c, 
        INDEX({
          "Q_SCq", "Amount of fuel type q used for stationary combustion operations", "Varies based on fuel type: kL, m3, GJ", "Input";
          "EC_SCq", "Energy content factor for stationary combustion operations", "GJ / unit of fuel", "Constant";
          "EF_SC1qg", "Scope 1 emission factor for stationary combustion for each greenhouse gas", "kg CO2e / GJ", "Constant";
          "q", "Fuel type", "", "Constant";
          "SC", "Stationary combustion", "", "Constant";
          "g", "Greenhouse gas", "", "Constant";
          "1", "Scope 1", "", "Constant"
        }, r, c)
      )
    )
  );

