/*
============================================================================
10.1: Waste
============================================================================
10.1.1.1 Method 1 - Solid Waste Treatment
============================================================================
*/

/*
--------------------------------------
VEERG_10_1_1_1__1_EmissionsFromWasteManagement
Emissions from waste management by greenhouse gas
E_g
t CO2e
E_g=\sum_t\sum_w(Q_wt\times EF_wtg)
Q_wt = quantity of solid waste of type w being sent to treatment facility t, on a wet weight basis (t)
EF_wtg = emission factor for greenhouse gas g for the management of waste at treatment facility t (t CO2e/t)
--------------------------------------
*/

VEERG_10_1_1_1__1_EmissionsFromWasteManagement
  =LAMBDA(
    Q_wt, EF_wtg,
    Q_wt * EF_wtg
  );

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_Title
  =LAMBDA("Emissions from waste management by greenhouse gas");

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_Variable
  =LAMBDA("E_g");

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_Unit
  =LAMBDA("t CO2e");

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_Source
  =LAMBDA("VEERG 2026: 10.1.1.1, Equation (1)");

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_NIRReference
  =LAMBDA("");

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_LatexEquation
  =LAMBDA("E_g=\sum\nolimits_t\sum\nolimits_w(Q_{wt}\times EF_{wtg})");

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_Arguments
  =LAMBDA(
    MAKEARRAY(7, 4,
      LAMBDA(r,c,
        INDEX({
          "Q_wt", "quantity of solid waste of type w being sent to treatment facility t, on a wet weight basis", "t", "Sum of Q_volwt and Q_masswt";
          "EF_wtg", "emission factor for greenhouse gas g for the management of waste at treatment facility t", "t CO2e/t", "Constant";
          "w", "waste type", "", "Input";
          "t", "treatment facility", "", "Input";
          "g", "greenhouse gas", "", "Input";
          "Q_volwt", "quantity of sold waste input as volume and converted to tonnes", "tonnes", "Calculated from 10.1.1.1 (2)";
          "Q_masswt", "quantity of solid waste input as mass", "tonnes", "Input"
        }, r, c)
      )
    )
  );

VEERG_10_1_1_1__1_EmissionsFromWasteManagement_Variation
  =LAMBDA("VARIATION ON SOURCE: Added Q_volwt and Q_masswt variables to clearly track input or calculated Q values");

/*
--------------------------------------
VEERG_10_1_1_1__2_MassOfWasteFromVolume
Mass of waste from waste volume
Q_wt
t
Q_wt=V_wt\times VTM_w
V_wt = volume of solid waste type w being sent to treatment facility t (m3)
VTM_w = conversion factor of volume to mass for waste type w (t/m3)
--------------------------------------
*/

VEERG_10_1_1_1__2_MassOfWasteFromVolume
  =LAMBDA(
    V_wt, VTM_w,
    V_wt * VTM_w
  );

VEERG_10_1_1_1__2_MassOfWasteFromVolume_Title
  =LAMBDA("Mass of waste from waste volume");

VEERG_10_1_1_1__2_MassOfWasteFromVolume_Variable
  =LAMBDA("Q_wt");

VEERG_10_1_1_1__2_MassOfWasteFromVolume_Unit
  =LAMBDA("t");

VEERG_10_1_1_1__2_MassOfWasteFromVolume_Source
  =LAMBDA("VEERG 2026: 10.1.1.1, Equation (2)");

VEERG_10_1_1_1__2_MassOfWasteFromVolume_NIRReference
  =LAMBDA("");

VEERG_10_1_1_1__2_MassOfWasteFromVolume_LatexEquation
  =LAMBDA("Q_{wt}=V_{wt}\times VTM_w");

VEERG_10_1_1_1__2_MassOfWasteFromVolume_Arguments
  =LAMBDA(
    MAKEARRAY(4, 4,
      LAMBDA(r,c,
        INDEX({
          "V_wt", "volume of solid waste type w being sent to treatment facility t", "m3", "Input";
          "VTM_w", "conversion factor of volume to mass for waste type w", "t/m3", "Constant";
          "w", "waste type", "", "Input";
          "t", "treatment facility", "", "Input"
        }, r, c)
      )
    )
  );
