Utility_GetArrayTableRowStartNumber
=LAMBDA(
    TableheaderCell,RowsBetweenHeaderandArray,
    ROW(TableheaderCell) + RowsBetweenHeaderandArray - 1
);

Utility_GetArrayTableColumnStartNumber
=LAMBDA(
  TableHeaderCell,
  COLUMN(TableHeaderCell)
);

Utility_DisplayArrayInTable
=LAMBDA(
 ArrayData, TableheaderCell, RowsBetweenHeaderandArray, [ColumnsBetweenHeaderAndArray],
 IFERROR(
     INDEX(
            UNIQUE(ArrayData), 
            ROW()-Utility_GetArrayTableRowStartNumber(TableheaderCell, RowsBetweenHeaderandArray), 
            COLUMN()-Utility_GetArrayTableColumnStartNumber(TableheaderCell) +
            IF(ISOMITTED(ColumnsBetweenHeaderAndArray), 1, ColumnsBetweenHeaderAndArray)
        ), ""
    )
);

Utility_LookupValueInTable
=LAMBDA(
    LookupValue, LookupArray, ReturnArray,
    XLOOKUP(LookupValue, LookupArray, ReturnArray, "")
);

Utility_LookupValueInTableNumber
=LAMBDA(
    LookupValue, LookupArray, ReturnArray,
    IF(ISNUMBER(
        XLOOKUP(LookupValue, LookupArray, ReturnArray, "")
    ), XLOOKUP(LookupValue, LookupArray, ReturnArray, ""), 0)
);

Utility_SplitStringIntoArray
=LAMBDA(
    Cell, Delimiter, [CharacterToRemove1], [CharacterToRemove2],
        FILTERXML(
        "<t><s>" &
        SUBSTITUTE(
            SUBSTITUTE(SUBSTITUTE(Cell,CharacterToRemove1,""),CharacterToRemove2,""),
            Delimiter,"</s><s>"
        ) &
        "</s></t>",
        "//s"
    )
);

Utility_GetClimateZone
=LAMBDA(
    avgTemp,avgRain,frostDays,elev,map_pet,
    minTempArray,maxTempArray,
    minRainfallArray,maxRainfallArray,
    minFrostArray,maxFrostArray,
    minElevationArray,maxElevationArray,
    minPETArray,maxPETArray,
    climateZoneArray,
    LET(
        mask,
        (VALUE(minTempArray)<=avgTemp)*
        (VALUE(maxTempArray)>=avgTemp)*
        (VALUE(minRainfallArray)<=avgRain)*
        (VALUE(maxRainfallArray)>=avgRain)*
        (VALUE(minFrostArray)<=frostDays)*
        (VALUE(maxFrostArray)>=frostDays)*
        (VALUE(minElevationArray)<=elev)*
        (VALUE(maxElevationArray)>=elev)*
        (VALUE(minPETArray)<=map_pet)*
        (VALUE(maxPETArray)>=map_pet),
        TAKE(
            FILTER(climateZoneArray,mask, "No match"),
            1
        )
    )
);

Utility_LookupItemFromMinMax
=LAMBDA(
    LookupValue, MinArray, MaxArray, ItemArray,
    LET(
        mask,
        (VALUE(MinArray)<=LookupValue)*
        (VALUE(MaxArray)>=LookupValue),
        FILTER(ItemArray, mask, "No match")
    )
);

Utility_SumQuantityFromCriteria
=LAMBDA(
  Criteria1, Criteria1TypeArray, Quantity, [Multiplier], [Criteria2],[Criteria2Array],
  LET(
    multiplier, IF(ISOMITTED(Multiplier),1,Multiplier),
    quantity, Quantity*Multiplier,
    criteria1,--(Criteria1TypeArray=Criteria1),
    criteria2,IF(ISOMITTED(Criteria2),1,--(Criteria2Array=Criteria2)),
    SUMPRODUCT(criteria1*criteria2*quantity)
  )
);

getOverlappingReportingCycles
=LAMBDA(
    ProductionCycleStart,ProductionCycleEnd,ReportingCycleStart,
    LET(
        S,ProductionCycleStart,
        E,ProductionCycleEnd,
        m,MONTH(ReportingCycleStart),
        d,DAY(ReportingCycleStart),
        PeriodEnd,LAMBDA(st,EDATE(st,12)-1),
        A,S-365,
        ya,YEAR(A),
        yb,YEAR(E),
        firstYear,ya+(PeriodEnd(DATE(ya,m,d))< S),
        lastYear,yb-(DATE(yb,m,d)> E),
        MAX(0,lastYear-firstYear+1)
    )
);

getOverlappingReportingPeriods
=LAMBDA(
    ProductionCycleStart,ProductionCycleEnd,ReportingCycleStart,
    LET(
        S,ProductionCycleStart,
        E,ProductionCycleEnd,
        m,MONTH(ReportingCycleStart),
        d,DAY(ReportingCycleStart), /*helper: end date for a reporting period starting at a given date*/
        PeriodEnd,LAMBDA(st,EDATE(st,12)-1), /*only need to look back 365 days(max overlap window)*/
        A,S-365,
        ya,YEAR(A),
        yb,YEAR(E), /*if the anchor for ya ends before S,it can't overlap; move to next year*/
        firstYear,ya+(PeriodEnd(DATE(ya,m,d))<S), /*if the anchor for yb starts after E,it can't overlap; move to previous year*/
        lastYear,yb-(DATE(yb,m,d)>E),
        n,MAX(0,lastYear-firstYear+1),
        yrs,SEQUENCE(n,1,firstYear,1),
        starts,DATE(yrs,m,d),
        ends,MAP(starts,PeriodEnd),
        tag,IF(starts=ReportingCycleStart," (This reporting cycle)",""),
        startsText,TEXT(starts,"dd mmm yyyy"),
        endsText,TEXT(ends,"dd mmm yyyy"),
        IF(n=0,"",HSTACK(startsText & " to " & endsText & tag))
    )
);

Utility_DisplayFunctionName
=LAMBDA(Function, TEXTBEFORE(FORMULATEXT(Function), "("));

Utility_LookupN2OEFFromProdIrrigationRainfall
=LAMBDA(
    ProductionSystem, IrrigationMethod, RainfallZone,
    ProductionSystemArray, IrrigationMethodArray, RainfallZoneArray,ReturnArray,
    LET(
        IrrigationMethod, IF(IrrigationMethod="Not irrigated", "Not irrigated", "Any"),
        RainfallZone, IF(IrrigationMethod = "Not irrigated", RainfallZone, "Any"),
        XLOOKUP(1, 
            (ProductionSystemArray=ProductionSystem)*
            (IrrigationMethodArray=IrrigationMethod)*
            (RainfallZoneArray=RainfallZone), 
            ReturnArray)
    )
);