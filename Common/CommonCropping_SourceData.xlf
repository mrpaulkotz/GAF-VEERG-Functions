/* 
--------------------------------------
CommonCropping_SourceData_N2OEFsInorganicFertiliser
Table 5.21 Nitrous oxide EFs for inorganic fertiliser
--------------------------------------
*/

CommonCropping_SourceData_N2OEFsInorganicFertiliser_Title
  =LAMBDA("Nitrous oxide EFs for inorganic fertiliser");

CommonCropping_SourceData_N2OEFsInorganicFertiliser_Unit
  =LAMBDA("Gg N2O-N/ Gg N");

CommonCropping_SourceData_N2OEFsInorganicFertiliser_Source
  =LAMBDA("National Inventory Report 2023 Volume 1: Table 5.21");

CommonCropping_SourceData_N2OEFsInorganicFertiliser_Data
  =LAMBDA(
    MAKEARRAY(8, 2, 
      LAMBDA(r,c, 
        INDEX({
          "Production system", "Emission factor";
            "Irrigated pasture", 0.0059;
            "Irrigated crop", 0.007;
            "Non-irrigated pasture", 0.0018;
            "Non-irrigated crop", 0.0041;
            "Sugar cane", 0.0199;
            "Cotton", 0.0053;
            "Horticulture", 0.0064
        }, r, c)
      )
    )
  );

