Fraction of inorganic fertiliser f that volatilises as NH3 and NOx
--------------------------------------
*/

CommonCropping_SourceData_FracGASFfInorganicFertiliser_Title
  =LAMBDA("The direct nitrous oxide EF from the organic fertiliser when applied to soils");

CommonCropping_SourceData_FracGASFfInorganicFertiliser_Unit
  =LAMBDA("(kg NH3-N + NOx-N)/kg N");

CommonCropping_SourceData_FracGASFfInorganicFertiliser_Source
  =LAMBDA("VEERG 2026:Table 12.2.2.9");

CommonCropping_SourceData_FracGASFfInorganicFertiliser_NIRReference
  =LAMBDA("IPCC 2019 Refinement Volume 4 Table 11.3 [1, p. 11]");

CommonCropping_SourceData_FracGASFfInorganicFertiliser_Data
  =LAMBDA(
    MAKEARRAY(6, 3, 
      LAMBDA(r,c, 
        INDEX({
