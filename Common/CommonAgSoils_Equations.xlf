Agsoils_MassVolatilisedInorganicFertiliser_Arguments
  =LAMBDA(
    MAKEARRAY(2, 3, 
      LAMBDA(r,c, 
        INDEX({
          "MNf","Mass of nitrogen in inorganic fertiliser applied","kg N";
          "FracGASFf","Fraction of inorganic fertiliser that volatilises","(kg NH3–N + NOx–N)/kg N"
        }, r, c)
      )
    )
  );


