{
  "schemaVersion": 1,
  "description": "Catalog that maps each VEERG module to its source workbook, the worksheets it contributes, and the Excel Labs (AFE) modules it needs. Enterprise files (Enterprise_*.json) reference these modules by key. This registry is the single place where module -> workbook/sheet/labs wiring lives, so it is not repeated in every enterprise file.",

  "sheetSourceModel": {
    "description": "Every sheet in an enterprise workbook is either 'import' or 'custom'. 'import' = the sheet is copied as-is from a module's source workbook; because input cells and input tables are exposed as named ranges, imported calculation sheets keep working no matter which sheet they land on (they resolve inputs by name, not by Sheet!Cell). 'custom' = the sheet is unique to the enterprise and is built by the enterprise (declared in the enterprise file's 'customSheets', e.g. the roll-up Results sheet or an enterprise-level input sheet). A module's sheets below default to 'import'. An enterprise file may subset which of a module's listed sheets to import via a per-module 'include' block.",
    "namedRangeContract": "Imported calculation sheets must reference inputs/tables AND result cells by workbook-scoped named range (X_Cell_* / X_Table_* / Table_Input* for inputs; result cells are likewise named ranges), never by Sheet!Cell, so sheets can be relocated, deduped, or replaced by a custom sheet without breaking references.",
    "resultsSheets": "Module Results tabs are never imported. The enterprise provides a single custom Results sheet (declared in the enterprise file's 'customSheets') that reads each module's result named ranges directly. This is why module 'sheets' below list only input/calculation/constants."
  },

  "templateWorkbook": "Enterprise_BeefPasture_WIP_v01.xlsx",

  "common": {
    "description": "Sheets and Excel Labs modules included once in every enterprise workbook, regardless of which modules are selected. 'strategy' tells a future builder where each sheet comes from: 'template' = copied from templateWorkbook; 'dedupe' = copied once from the first selected module workbook that contains it (identical across modules); 'generate' = assembled by the enterprise builder from each module's contribution.",
    "sheets": [
      { "name": "Home", "strategy": "template" },
      { "name": "Overview", "strategy": "template" },
      { "name": "Input - Site", "strategy": "dedupe" },
      { "name": "Constants - Common", "strategy": "dedupe" },
      { "name": "Acknowledgements", "strategy": "template" }
    ],
    "excelLabsModules": [
      "Common_Equations",
      "Common_InputFunctions",
      "Common_SourceData"
    ]
  },

  "sheetGroups": {
    "description": "Shared building blocks pulled in once when at least one member module requests the group, then deduped. Referenced by a module's 'groups' array.",
    "Livestock": {
      "sheets": ["Constants - Livestock"],
      "excelLabsModules": ["CommonLivestock_SourceData"]
    },
    "Cropping": {
      "sheets": [],
      "excelLabsModules": ["CommonCropping_InputFunctions"]
    }
  },

